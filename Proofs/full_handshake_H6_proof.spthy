                               <'8', '13', 'encryptedExtensions'>, '11', 
                               ServerCertificate_1.1502, ServerCertificate_2.1503, 
                               ServerCertificate_3.1504, ServerCertificate_4.1505, 
                               ServerCertificate_5.1506>), 
                           ServerCertificate_1.1502, ServerCertificate_2.1503, 
                           ServerCertificate_3.1504, ServerCertificate_4.1505, 
                           ServerCertificate_5.1506>),
                     x.2992)
        server_session_id
              = server_session_id.1521
        z     = x.2980^(x.2977*x.2981*inv((x.2979*x.2982)))
        z.1   = 'g'^(x.2976*x.2977*inv((x.2978*x.2979)))
        z.2   = true
  */

rule (modulo E) ClientFinishedAuth:
   [
   Fr( ~msg_len ), Fr( ~msg_len_1 ), Fr( ~msg_len_2 ),
   St_ClientHelloCookie( <$C, $S, a, session_id, ClientHello, 
                          HelloRetryRequest, ClientHelloCookie>,
                         <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
   ),
   !Pk( $S, serverPublicKey ),
   In( <
        <'22', %rec_epoch, %rec_seq, lenSH, '2', 
         <lenSH, %rec_seq, %offSH, %fragSH>, protocolVersion, 
         server_session_id, 'CipherSuits', '51', 'g', gb>, 
        $S, $C>
   ),
   In( <
        <handshakeCryptoHeader, %1, 
         senc(<
               <'8', <lenEE, %1, %offEE, %fragEE>, '13', 'encryptedExtensions'>, 
               '0', '22'>,
              gb^a)
        >, 
        $S, $C>
   ),
   In( <
        <handshakeCryptoHeader, (%1%+%1%+%1), 
         senc(<
               <'11', <lenSC_1, (%1%+%1%+%1), %offSC_1, %fragSC_1>, 
                ServerCertificate_1>, 
               '0', '22'>,
              gb^a)
        >, 
        $S, $C>
   ),
   In( <
        <handshakeCryptoHeader, (%1%+%1%+%1), 
         senc(<
               <'11', <lenSC_2, (%1%+%1%+%1), %offSC_2, %fragSC_2>, 
                ServerCertificate_2>, 
               '0', '22'>,
              gb^a)
        >, 
        $S, $C>
   ),
   In( <
        <handshakeCryptoHeader, (%1%+%1%+%1), 
         senc(<
               <'11', <lenSC_3, (%1%+%1%+%1), %offSC_3, %fragSC_3>, 
                ServerCertificate_3>, 
               '0', '22'>,
              gb^a)
        >, 
        $S, $C>
   ),
   In( <
        <handshakeCryptoHeader, (%1%+%1%+%1), 
         senc(<
               <'11', <lenSC_4, (%1%+%1%+%1), %offSC_4, %fragSC_4>, 
                ServerCertificate_4>, 
               '0', '22'>,
              gb^a)
        >, 
        $S, $C>
   ),
   In( <
        <handshakeCryptoHeader, (%1%+%1%+%1), 
         senc(<
               <'11', <lenSC_5, (%1%+%1%+%1), %offSC_5, %fragSC_5>, 
                ServerCertificate_5>, 
               '0', '22'>,
              gb^a)
        >, 
        $S, $C>
   ),
   In( <
        <handshakeCryptoHeader, (%1%+%1%+%1%+%1), 
         senc(<
               <'15', <lenSCV, (%1%+%1%+%1%+%1), %offSCV, %fragSCV>, $alg, 
                serverSignature>, 
               '0', '22'>,
              gb^a)
        >, 
        $S, $C>
   ),
   In( <
        <handshakeCryptoHeader, (%1%+%1%+%1%+%1%+%1), 
         senc(<
               <'20', <lenSF, (%1%+%1%+%1%+%1%+%1), %offSF, %fragSF>, 
                server_finished>, 
               '0', '22'>,
              gb^a)
        >, 
        $S, $C>
   ),
   In( <
        <handshakeCryptoHeader, (%1%+%1), 
         senc(<<'13', <lenCR, (%1%+%1), %offCR, %fragCR>, $client_alg>, 
               '0', '22'>,
              gb^a)
        >, 
        $S, $C>
   ),
   !Ltk( $C, clientPrivateKey )
   ]
  --[
  Instance( session_id, $C, 'client' ),
  HandshakeComplete( $C, $S, 'client', gb^a,
                     <session_id, server_session_id>
  ),
  Reach( 'CFAuth' ),
  DHChal( $C, session_id, 'g', a, 'g'^a, gb, gb^a ),
  SessionKey( $C, $S, 'client', session_id, gb^a, 'auth' ),
  FragmentsInOrder( %offSC_1, %offSC_2, %offSC_3, %offSC_4, %offSC_5
  ),
  Nonce( $C, <session_id, server_session_id> ),
  Running( $C, 'client', session_id,
           <ClientHello, HelloRetryRequest, ClientHelloCookie, 
            <'2', protocolVersion, server_session_id, 'CipherSuits', '51', 
             'g', gb>, 
            <'8', '13', 'encryptedExtensions'>, 
            <'11', ServerCertificate_1, ServerCertificate_2, 
             ServerCertificate_3, ServerCertificate_4, ServerCertificate_5>, 
            <'15', $alg, serverSignature>, '20', server_finished>,
           gb^a
  ),
  CommitAuth( $C, $S, 'client', session_id,
              <ClientHello, HelloRetryRequest, ClientHelloCookie, 
               <'2', protocolVersion, server_session_id, 'CipherSuits', '51', 
                'g', gb>, 
               <'8', '13', 'encryptedExtensions'>, 
               <'11', ServerCertificate_1, ServerCertificate_2, 
                ServerCertificate_3, ServerCertificate_4, ServerCertificate_5>, 
               '15', $alg, serverSignature>,
              gb^a
  ),
  Neq( 'g', gb ), Neq( gb, gb^a ),
  Eq( hmac(<HKDFExpand(<gb^a, 'finished', 'Hash_length'>), 
            h1(<ClientHello, HelloRetryRequest, ClientHelloCookie, 
                <'2', protocolVersion, server_session_id, 'CipherSuits', '51', 
                 'g', gb>, 
                <'8', '13', 'encryptedExtensions'>, 
                <'11', ServerCertificate_1, ServerCertificate_2, 
                 ServerCertificate_3, ServerCertificate_4, ServerCertificate_5>, 
                '15', $alg, serverSignature>)
           >),
      server_finished
  ),
  Eq( verify(serverSignature,
             hmac(<
                   h1(<ClientHello, HelloRetryRequest, ClientHelloCookie, 
                       <'2', protocolVersion, server_session_id, 'CipherSuits', '51', 
                        'g', gb>, 
                       <'8', '13', 'encryptedExtensions'>, '11', ServerCertificate_1, 
                       ServerCertificate_2, ServerCertificate_3, ServerCertificate_4, 
                       ServerCertificate_5>), 
                   ServerCertificate_1, ServerCertificate_2, ServerCertificate_3, 
                   ServerCertificate_4, ServerCertificate_5>),
             serverPublicKey),
      true
  ),
  ClientCert( $C, $S, session_id, 'clientCert' ),
  Send( $C, $S, 'CF', session_id )
  ]->
   [
   Out( <
         <handshakeCryptoHeader, (%next_seq%+%1%+%1), 
          senc(<
                <'20', <~msg_len, (%next_seq%+%1%+%1), %1, %1>, 
                 hmac(<HKDFExpand(<gb^a, 'finished', 'Hash_length'>), 
                       h1(<ClientHello, HelloRetryRequest, ClientHelloCookie, 
                           <'2', protocolVersion, server_session_id, 'CipherSuits', '51', 
                            'g', gb>, 
                           <'8', '13', 'encryptedExtensions'>, 
                           <'11', ServerCertificate_1, ServerCertificate_2, 
                            ServerCertificate_3, ServerCertificate_4, ServerCertificate_5>, 
                           '15', $alg, serverSignature>)
                      >)
                >, 
                <'0', '0'>, '22'>,
               gb^a)
         >, 
         $C, $S>
   ),
   Out( <
         <handshakeCryptoHeader, %next_seq, 
          senc(<<'11', <~msg_len_1, %next_seq, %1, %1>, 'clientCert'>, '0', 
                '22'>,
               gb^a)
         >, 
         $C, $S>
   ),
   Out( <
         <handshakeCryptoHeader, (%next_seq%+%1), 
          senc(<
                <'15', <~msg_len_2, (%next_seq%+%1), %1, %1>, $client_alg, 
                 sign(hmac(<
                            h1(<ClientHello, HelloRetryRequest, ClientHelloCookie, 
                                <'2', protocolVersion, server_session_id, 'CipherSuits', '51', 
                                 'g', gb>, 
                                <'8', '13', 'encryptedExtensions'>, 
                                <'11', ServerCertificate_1, ServerCertificate_2, 
                                 ServerCertificate_3, ServerCertificate_4, ServerCertificate_5>, 
                                <'15', $alg, serverSignature>, '20', server_finished>), 
                            'clientCert'>),
                      clientPrivateKey)
                >, 
                '0', '22'>,
               gb^a)
         >, 
         $C, $S>
   )
   ]

  /*
