rule (modulo E) Ack:
   [
   In( <
        <handshakeCryptoHeader, %rec_seq, 
         senc(<<'11', <lenCC, %rec_seq, %offCC, %fragCC>, 'clientCert'>, 
               '0', '22'>,
              traffic_key)
        >, 
        $C, $S>
   ),
   In( <
        <handshakeCryptoHeader, (%rec_seq%+%1), 
         senc(<
               <'15', <lenCV, (%rec_seq%+%1), %offCV, %fragCV>, $client_alg, 
                clientSignature>, 
               '0', '22'>,
              traffic_key)
        >, 
        $C, $S>
   ),
   In( <
        <handshakeCryptoHeader, (%rec_seq%+%1%+%1), 
         senc(<
               <'20', <lenCF, (%rec_seq%+%1%+%1), %offCF, %fragCF>, 
                client_finished>, 
               <'0', '0'>, '22'>,
              traffic_key)
        >, 
        $C, $S>
   ),
   !Pk( $C, clientPublicKey ),
   !Keys( <$S, $C, session_id, gb, ga, traffic_key> ),
   St_ServerFinished( <$S, $C, session_id, ClientHello, 
                       HelloRetryRequest, ClientHelloCookie, ServerHello, 
                       EncryptedExtensions, ServerCertificate, CertificateVerify, 
                       ServerFinished>,
                      <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>,
                      <CHRecordNumbers, CHCRecrodNumbers>
   ),
   ServerFinished( <$S, $C, finished_key>,
                   <$S, $C, server_finished, nonce>
   ),
   CertificateRequested( auth_status )
   ]
  --[
  Instance( session_id, $S, 'server' ),
  Eq( client_finished, server_finished ), Eq( auth_status, 'True' ),
  Reach( 'ACK' ),
  Eq( verify(clientSignature,
             hmac(<
                   h1(<ClientHello, HelloRetryRequest, ClientHelloCookie, 
                       ServerHello, EncryptedExtensions, ServerCertificate, 
                       CertificateVerify, ServerFinished>), 
                   'clientCert'>),
             clientPublicKey),
      true
  ),
  CommitAuth( $S, $C, 'server', session_id,
              <ClientHello, HelloRetryRequest, ClientHelloCookie, ServerHello, 
               EncryptedExtensions, ServerCertificate, CertificateVerify, 
               ServerFinished>,
              traffic_key
  ),
  HandshakeComplete( $S, $C, 'server', traffic_key, nonce ),
  SessionKey( $S, $C, 'server', session_id, traffic_key, 'auth' ),
  Send( $S, $C, 'ACK', session_id )
  ]->
   [
   Out( <handshakeCryptoHeader, %next_seq, 
         senc(<
               <CHRecordNumbers, CHCRecrodNumbers, <(%1%+%1%+%1), %rec_seq>, 
                <(%1%+%1%+%1), (%rec_seq%+%1)>, (%1%+%1%+%1), (%rec_seq%+%1%+%1)>, 
               <'0', '0'>, '26'>,
              traffic_key)
        >
   )
   ]

  /*
  rule (modulo AC) Ack:
     [
     In( <
          <<<'0', '0', '1'>, '0', '1', '1', '1', '0'>, %rec_seq, 
           senc(<<'11', <lenCC, %rec_seq, %offCC, %fragCC>, 'clientCert'>, 
                 '0', '22'>,
                traffic_key)
          >, 
          $C, $S>
     ),
     In( <
          <<<'0', '0', '1'>, '0', '1', '1', '1', '0'>, (%rec_seq%+%1), 
           senc(<
                 <'15', <lenCV, (%rec_seq%+%1), %offCV, %fragCV>, $client_alg, 
                  clientSignature>, 
                 '0', '22'>,
                traffic_key)
          >, 
          $C, $S>
     ),
     In( <
          <<<'0', '0', '1'>, '0', '1', '1', '1', '0'>, (%rec_seq%+%1%+%1), 
           senc(<
                 <'20', <lenCF, (%rec_seq%+%1%+%1), %offCF, %fragCF>, 
                  client_finished>, 
                 <'0', '0'>, '22'>,
                traffic_key)
          >, 
          $C, $S>
     ),
     !Pk( $C, clientPublicKey ),
     !Keys( <$S, $C, session_id, gb, ga, traffic_key> ),
     St_ServerFinished( <$S, $C, session_id, ClientHello, 
                         HelloRetryRequest, ClientHelloCookie, ServerHello, 
                         EncryptedExtensions, ServerCertificate, CertificateVerify, 
                         ServerFinished>,
                        <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>,
                        <CHRecordNumbers, CHCRecrodNumbers>
     ),
     ServerFinished( <$S, $C, finished_key>,
                     <$S, $C, server_finished, nonce>
     ),
     CertificateRequested( auth_status )
     ]
    --[
    Instance( session_id, $S, 'server' ),
    Eq( client_finished, server_finished ), Eq( auth_status, 'True' ),
    Reach( 'ACK' ), Eq( z, true ),
    CommitAuth( $S, $C, 'server', session_id,
                <ClientHello, HelloRetryRequest, ClientHelloCookie, ServerHello, 
                 EncryptedExtensions, ServerCertificate, CertificateVerify, 
                 ServerFinished>,
                traffic_key
    ),
    HandshakeComplete( $S, $C, 'server', traffic_key, nonce ),
    SessionKey( $S, $C, 'server', session_id, traffic_key, 'auth' ),
    Send( $S, $C, 'ACK', session_id )
    ]->
     [
     Out( <<<'0', '0', '1'>, '0', '1', '1', '1', '0'>, %next_seq, 
           senc(<
                 <CHRecordNumbers, CHCRecrodNumbers, <(%1%+%1%+%1), %rec_seq>, 
                  <(%1%+%1%+%1), (%rec_seq%+%1)>, (%1%+%1%+%1), (%rec_seq%+%1%+%1)>, 
                 <'0', '0'>, '26'>,
                traffic_key)
          >
     )
     ]
    variants (modulo AC)
    1. CertificateVerify
             = CertificateVerify.61
       ClientHello
             = ClientHello.62
       ClientHelloCookie
             = ClientHelloCookie.63
       EncryptedExtensions
             = EncryptedExtensions.64
       HelloRetryRequest
             = HelloRetryRequest.65
       ServerCertificate
             = ServerCertificate.66
       ServerFinished
             = ServerFinished.67
       ServerHello
             = ServerHello.68
       clientPublicKey
             = clientPublicKey.70
       clientSignature
             = clientSignature.71
       z     = verify(clientSignature.71,
                      hmac(<
                            h1(<ClientHello.62, HelloRetryRequest.65, ClientHelloCookie.63, 
                                ServerHello.68, EncryptedExtensions.64, ServerCertificate.66, 
                                CertificateVerify.61, ServerFinished.67>), 
                            'clientCert'>),
                      clientPublicKey.70)
    
    2. CertificateVerify
             = CertificateVerify.555
       ClientHello
             = ClientHello.556
       ClientHelloCookie
             = ClientHelloCookie.557
       EncryptedExtensions
             = EncryptedExtensions.558
       HelloRetryRequest
             = HelloRetryRequest.559
       ServerCertificate
             = ServerCertificate.560
       ServerFinished
             = ServerFinished.561
       ServerHello
             = ServerHello.562
       clientPublicKey
             = pk(x.1103)
       clientSignature
             = sign(hmac(<
                          h1(<ClientHello.556, HelloRetryRequest.559, ClientHelloCookie.557, 
                              ServerHello.562, EncryptedExtensions.558, ServerCertificate.560, 
                              CertificateVerify.555, ServerFinished.561>), 
                          'clientCert'>),
                    x.1103)
       z     = true
  */

rule (modulo E) AckNoAuth:
   [
   In( <
        <handshakeCryptoHeader, %rec_seq, 
         senc(<<'20', <len, %rec_seq, %off, %frag>, client_finished>, 
               <'0', '0'>, '22'>,
              traffic_key)
        >, 
        $C, $S>
   ),
   St_ServerFinished( <$S, $C, session_id, ClientHello, 
                       HelloRetryRequest, ClientHelloCookie, ServerHello, 
                       EncryptedExtensions, ServerCertificate, CertificateVerify, 
                       ServerFinished>,
                      <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>,
                      <CHRecordNumbers, CHCRecrodNumbers>
   ),
   !Keys( <$S, $C, session_id, gb, ga, traffic_key> ),
   ServerFinished( <$S, $C, finished_key>,
                   <$S, $C, server_finished, nonce>
   ),
   CertificateRequested( auth_status )
   ]
  --[
  Instance( session_id, $S, 'server' ),
  Eq( client_finished, server_finished ), Eq( auth_status, 'False' ),
  Reach( 'ACKNoAuth' ),
  HandshakeComplete( $S, $C, 'server', traffic_key, nonce ),
  SessionKey( $S, $C, 'server', session_id, traffic_key, 'not_auth'
  ),
  Send( $S, $C, 'ACK', session_id )
  ]->
   [
   Out( <handshakeCryptoHeader, %next_seq, 
         senc(<<CHRecordNumbers, CHCRecrodNumbers, (%1%+%1%+%1), %rec_seq>, 
               <'0', '0'>, '26'>,
              traffic_key)
        >
   )
   ]

  /*
  rule (modulo AC) AckNoAuth:
     [
     In( <
          <<<'0', '0', '1'>, '0', '1', '1', '1', '0'>, %rec_seq, 
           senc(<<'20', <len, %rec_seq, %off, %frag>, client_finished>, 
                 <'0', '0'>, '22'>,
                traffic_key)
          >, 
          $C, $S>
     ),
     St_ServerFinished( <$S, $C, session_id, ClientHello, 
                         HelloRetryRequest, ClientHelloCookie, ServerHello, 
                         EncryptedExtensions, ServerCertificate, CertificateVerify, 
                         ServerFinished>,
                        <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>,
                        <CHRecordNumbers, CHCRecrodNumbers>
     ),
     !Keys( <$S, $C, session_id, gb, ga, traffic_key> ),
     ServerFinished( <$S, $C, finished_key>,
                     <$S, $C, server_finished, nonce>
     ),
     CertificateRequested( auth_status )
     ]
    --[
    Instance( session_id, $S, 'server' ),
    Eq( client_finished, server_finished ), Eq( auth_status, 'False' ),
    Reach( 'ACKNoAuth' ),
    HandshakeComplete( $S, $C, 'server', traffic_key, nonce ),
    SessionKey( $S, $C, 'server', session_id, traffic_key, 'not_auth'
    ),
    Send( $S, $C, 'ACK', session_id )
    ]->
     [
     Out( <<<'0', '0', '1'>, '0', '1', '1', '1', '0'>, %next_seq, 
           senc(<<CHRecordNumbers, CHCRecrodNumbers, (%1%+%1%+%1), %rec_seq>, 
                 <'0', '0'>, '26'>,
                traffic_key)
          >
     )
     ]
  */

restriction Equal:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

  /*
  expanded formula:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  */

restriction Not_equal:
  "∀ x y #i. (Neq( x, y ) @ #i) ⇒ (¬(x = y))"
  // safety formula

  /*
  expanded formula:
  "∀ x y #i. (Neq( x, y ) @ #i) ⇒ (¬(x = y))"
  */

restriction Only_one_ltk_per_actor:
  "∀ A #i #j. ((Reg( A ) @ #i) ∧ (Reg( A ) @ #j)) ⇒ (#i = #j)"
  // safety formula

  /*
  expanded formula:
  "∀ A #i #j. ((Reg( A ) @ #i) ∧ (Reg( A ) @ #j)) ⇒ (#i = #j)"
  */

lemma V1_Reachability_with_both_actors [use_induction]:
  exists-trace
  "∃ C S client_session_id server_session_id traffic_key #i #j #k #l.
    ((((((Start( C, S, 'client', client_session_id ) @ #i) ∧
         (Start( S, C, 'server', server_session_id ) @ #j)) ∧
        (HandshakeComplete( C, S, 'client', traffic_key,
                            <client_session_id, server_session_id>
         ) @ #k)) ∧
       (HandshakeComplete( S, C, 'server', traffic_key,
                           <client_session_id, server_session_id>
        ) @ #l)) ∧
      (¬(∃ #p. Corrupt( C ) @ #p))) ∧
     (¬(∃ #q. Corrupt( S ) @ #q))) ∧
    (¬(∃ #r. K( traffic_key ) @ #r))"
/*
guarded formula characterizing all satisfying traces:
"∃ C S client_session_id server_session_id traffic_key #i #j #k #l.
  (Start( C, S, 'client', client_session_id ) @ #i) ∧
  (Start( S, C, 'server', server_session_id ) @ #j) ∧
  (HandshakeComplete( C, S, 'client', traffic_key,
                      <client_session_id, server_session_id>
   ) @ #k) ∧
  (HandshakeComplete( S, C, 'server', traffic_key,
                      <client_session_id, server_session_id>
   ) @ #l)
 ∧
  (∀ #p. (Corrupt( C ) @ #p) ⇒ ⊥) ∧
  (∀ #q. (Corrupt( S ) @ #q) ⇒ ⊥) ∧
  (∀ #r. (K( traffic_key ) @ #r) ⇒ ⊥)"
*/
by sorry

