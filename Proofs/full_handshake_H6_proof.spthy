lemma H6_Forward_secrecy:
  all-traces
  "∀ C S key session_id1 session_id2 #i #j.
    (((((HandshakeComplete( C, S, 'client', key,
                            <session_id1, session_id2>
         ) @ #i) ∧
        (HandshakeComplete( S, C, 'server', key, <session_id1, session_id2>
         ) @ #j)) ∧
       (#i < #j)) ∧
      ((∃ ltk #p. (RevLTK( C, ltk ) @ #p) ∧ (#j < #p)) ∨
       (∃ ltk #q. (RevLTK( S, ltk ) @ #q) ∧ (#j < #q)))) ∧
     (¬(∃ #k. (K( key ) @ #k) ∧ (#k < #j)))) ⇒
    (((¬(∃ #k. K( key ) @ #k)) ∨
      (∃ #p a. RevDHExp( a, session_id1, C ) @ #p)) ∨
     (∃ #q b. RevDHExp( b, session_id2, S ) @ #q))"
/*
guarded formula characterizing all counter-examples:
"∃ C S key session_id1 session_id2 #i #j.
  (HandshakeComplete( C, S, 'client', key, <session_id1, session_id2>
   ) @ #i) ∧
  (HandshakeComplete( S, C, 'server', key, <session_id1, session_id2>
   ) @ #j)
 ∧
  (#i < #j) ∧
  (((∃ ltk #p. (RevLTK( C, ltk ) @ #p) ∧ #j < #p) ∨
    (∃ ltk #q. (RevLTK( S, ltk ) @ #q) ∧ #j < #q))) ∧
  (∀ #k. (K( key ) @ #k) ⇒ ¬(#k < #j)) ∧
  (∃ #k. (K( key ) @ #k)) ∧
  (∀ #p a. (RevDHExp( a, session_id1, C ) @ #p) ⇒ ⊥) ∧
  (∀ #q b. (RevDHExp( b, session_id2, S ) @ #q) ⇒ ⊥)"
*/
simplify
solve( (∃ ltk #p. (RevLTK( C, ltk ) @ #p) ∧ #j < #p)  ∥
       (∃ ltk #q. (RevLTK( S, ltk ) @ #q) ∧ #j < #q) )
  case case_1
  solve( (#k = #j)  ∥ (#j < #k) )
    case case_1
    solve( !Ltk( $A, ~ltk ) ▶₀ #p )
      case Register_pk
      solve( HandshakeComplete( $A, S, 'client', key,
                                <session_id1, session_id2>
             ) @ #i )
        case ClientFinishedAuth
        solve( St_ClientHelloCookie( <$A, $S, a, session_id1, ClientHello, 
                                      HelloRetryRequest, ClientHelloCookie>,
                                     <session_id1, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
               ) ▶₃ #i )
          case ClientHelloCookie
          solve( (∀ #j. (K( ~a ) @ #j) ⇒ ⊥)  ∥
                 (∃ #k. (RevDHExp( ~a, ~session_id, $A ) @ #k)) )
            case case_1
            solve( !Pk( $S, pk(x) ) ▶₄ #i )
              case Register_pk
              solve( !Ltk( $A, clientPrivateKey ) ▶₁₅ #i )
                case Register_pk
                by solve( HandshakeComplete( $S, $A, 'server', key,
                                             <~session_id, session_id2>
                          ) @ #j )
              qed
            qed
          next
            case case_2
            by contradiction /* from formulas */
          qed
        qed
      next
        case ClientFinishedNoAuth
        solve( St_ClientHelloCookie( <$A, $S, a, session_id1, ClientHello, 
                                      HelloRetryRequest, ClientHelloCookie>,
                                     <session_id1, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
               ) ▶₁ #i )
          case ClientHelloCookie
          solve( (∀ #j. (K( ~a ) @ #j) ⇒ ⊥)  ∥
                 (∃ #k. (RevDHExp( ~a, ~session_id, $A ) @ #k)) )
            case case_1
            solve( !Pk( $S, pk(x) ) ▶₂ #i )
              case Register_pk
              by solve( HandshakeComplete( $S, $A, 'server', key,
                                           <~session_id, session_id2>
                        ) @ #j )
            qed
          next
            case case_2
            by contradiction /* from formulas */
          qed
        qed
      qed
    qed
  next
    case case_2
    solve( !Ltk( $A, ~ltk ) ▶₀ #p )
      case Register_pk
      solve( HandshakeComplete( $A, S, 'client', key,
                                <session_id1, session_id2>
             ) @ #i )
        case ClientFinishedAuth
        solve( !Pk( $S, pk(x) ) ▶₄ #i )
          case Register_pk
          solve( !Ltk( $A, clientPrivateKey ) ▶₁₅ #i )
            case Register_pk
            solve( St_ClientHelloCookie( <$A, $S, a, session_id1, ClientHello, 
                                          HelloRetryRequest, ClientHelloCookie>,
                                         <session_id1, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
                   ) ▶₃ #i )
              case ClientHelloCookie
              solve( splitEqs(1) )
                case split_case_1
                solve( HandshakeComplete( $S, $A, 'server', gb^~a,
                                          <~session_id, session_id2>
                       ) @ #j )
                  case Ack
                  solve( !Pk( $A, pk(x) ) ▶₃ #j )
                    case Register_pk
                    by solve( !Keys( <$S, $A, session_id.1, gb.1, ga, gb^~a> ) ▶₄ #j )
                  qed
                next
                  case AckNoAuth
                  by solve( !Keys( <$S, $A, session_id.1, gb.1, ga, gb^~a> ) ▶₂ #j )
                qed
              next
                case split_case_2
                solve( HandshakeComplete( $S, $A, 'server', key,
                                          <~session_id, session_id2>
                       ) @ #j )
                  case Ack
                  by solve( !Keys( <$S, $A, session_id.1, gb, ga, key> ) ▶₄ #j )
                next
                  case AckNoAuth
                  by solve( !Keys( <$S, $A, session_id.1, gb, ga, key> ) ▶₂ #j )
                qed
              next
                case split_case_3
                solve( HandshakeComplete( $S, $A, 'server', x^(~a*x.1),
                                          <~session_id, session_id2>
                       ) @ #j )
                  case Ack
                  solve( !Keys( <$S, $A, session_id.1, gb, ga, x^(~a*x.1)> ) ▶₄ #j )
                    case ServerHello
                    solve( !Pk( $A, pk(x.2) ) ▶₃ #j )
                      case Register_pk
                      solve( splitEqs(4) )
                        case split_case_1
                        solve( !KU( x^(~a*~b) ) @ #vk )
                          case ClientHello
                          solve( !KU( ~b ) @ #vk.161 )
                            case Reveal_DHExp
                            solve( St_ServerFinished( <$S, $A, ~session_id.1, ClientHello, 
                                                       HelloRetryRequest, ClientHelloCookie, 
                                                       ServerHello, EncryptedExtensions, 
                                                       ServerCertificate, CertificateVerify, 
                                                       ServerFinished>,
                                                      <~session_id.1, %next_seq, %next_epoch, 
                                                       %rec_seq, %rec_epoch>,
                                                      <CHRecordNumbers, CHCRecrodNumbers>
                                   ) ▶₅ #j )
                              case ServerFinished_case_1
                              solve( CertificateRequested( 'True' ) ▶₇ #j )
                                case ServerCertificateRequest
                                solve( ServerFinished( <$S, $A, finished_key>,
                                                       <$S, $A, client_finished, ~session_id, 
                                                        session_id2>
                                       ) ▶₆ #j )
                                  case ServerFinished_case_1
                                  solve( (∀ #j. (K( ~a ) @ #j) ⇒ ⊥)  ∥
                                         (∃ #k. (RevDHExp( ~a, ~session_id, $A ) @ #k)) )
                                    case case_1
                                    solve( (∀ #j. (K( ~b ) @ #j) ⇒ ⊥)  ∥
                                           (∃ #k. (RevDHExp( ~b, ~session_id.2, $S ) @ #k)) )
                                      case case_1
                                      solve( (∀ #j. (K( ~b.2 ) @ #j) ⇒ ⊥)  ∥
                                             (∃ #k. (RevDHExp( ~b.2, ~session_id.3, $S.1 ) @ #k)) )
                                        case case_1
                                        solve( (∀ #j. (K( ~b.1 ) @ #j) ⇒ ⊥)  ∥
                                               (∃ #k. (RevDHExp( ~b.1, ~session_id.1, $S ) @ #k)) )
                                          case case_1
                                          solve( (¬(#vr.4 < #vr.31))  ∥
                                                 (∃ traffic_key #k.
                                                   (HandshakeComplete( $S, $A, 'server',
                                                                       traffic_key,
                                                                       <~session_id.2, ~session_id.1
                                                                       >
                                                    ) @ #k)
                                                  ∧
                                                   (#k < #vr.31) ∧ (#vr.4 < #k)) )
                                            case case_1
                                            solve( (¬(#vr.31 < #vr.4))  ∥
                                                   (∃ traffic_key #k.
                                                     (HandshakeComplete( $S, $A, 'server',
                                                                         traffic_key,
                                                                         <~session_id.1, 
                                                                          ~session_id.2>
                                                      ) @ #k)
                                                    ∧
                                                     (#k < #vr.4) ∧ (#vr.31 < #k)) )
                                              case case_1
                                              solve( (#vr.4 = #vr.31)  ∥ (#vr.31 < #vr.4) )
                                                case case_1
                                                by contradiction /* from formulas */
                                              next
                                                case case_2
                                                by contradiction /* from formulas */
                                              qed
                                            next
                                              case case_2
                                              solve( HandshakeComplete( $S, $A, 'server',
                                                                        traffic_key.2,
                                                                        <~session_id.1, 
                                                                         ~session_id.2>
                                                     ) @ #k.1 )
                                                case Ack
                                                solve( St_ServerFinished( <$S, $A, session_id.3, 
                                                                           ClientHello, 
                                                                           HelloRetryRequest, 
                                                                           ClientHelloCookie, 
                                                                           ServerHello, 
                                                                           EncryptedExtensions, 
                                                                           ServerCertificate, 
                                                                           CertificateVerify, 
                                                                           ServerFinished>,
                                                                          <session_id.3, %next_seq, 
                                                                           %next_epoch, %rec_seq, 
                                                                           %rec_epoch.1>,
                                                                          <CHRecordNumbers, 
                                                                           CHCRecrodNumbers>
                                                       ) ▶₅ #k.1 )
                                                  case ServerFinished_case_1
                                                  by contradiction /* cyclic */
                                                next
                                                  case ServerFinished_case_2
                                                  by contradiction /* cyclic */
                                                qed
                                              next
                                                case AckNoAuth
                                                solve( St_ServerFinished( <$S, $A, session_id.3, 
                                                                           ClientHello, 
                                                                           HelloRetryRequest, 
                                                                           ClientHelloCookie, 
                                                                           ServerHello, 
                                                                           EncryptedExtensions, 
                                                                           ServerCertificate, 
                                                                           CertificateVerify, 
                                                                           ServerFinished>,
                                                                          <session_id.3, %next_seq, 
                                                                           %next_epoch, %rec_seq, 
                                                                           %rec_epoch.1>,
                                                                          <CHRecordNumbers, 
                                                                           CHCRecrodNumbers>
                                                       ) ▶₁ #k.1 )
                                                  case ServerFinished_case_1
                                                  by contradiction /* cyclic */
                                                next
                                                  case ServerFinished_case_2
                                                  by contradiction /* cyclic */
                                                qed
                                              qed
                                            qed
                                          next
                                            case case_2
                                            solve( HandshakeComplete( $S, $A, 'server',
                                                                      traffic_key.2,
                                                                      <~session_id.2, ~session_id.1>
                                                   ) @ #k.1 )
                                              case Ack
                                              solve( St_ServerFinished( <$S, $A, session_id.3, 
                                                                         ClientHello, 
                                                                         HelloRetryRequest, 
                                                                         ClientHelloCookie, 
                                                                         ServerHello, 
                                                                         EncryptedExtensions, 
                                                                         ServerCertificate, 
                                                                         CertificateVerify, 
                                                                         ServerFinished>,
                                                                        <session_id.3, %next_seq, 
                                                                         %next_epoch, %rec_seq, 
                                                                         %rec_epoch.1>,
                                                                        <CHRecordNumbers, 
                                                                         CHCRecrodNumbers>
                                                     ) ▶₅ #k.1 )
                                                case ServerFinished_case_1
                                                solve( (¬(#vr.4 < #vr.38))  ∥
                                                       (∃ traffic_key #k.
                                                         (HandshakeComplete( $S, $A, 'server',
                                                                             traffic_key,
                                                                             <~session_id.2, 
                                                                              ~session_id.3>
                                                          ) @ #k)
                                                        ∧
                                                         (#k < #vr.38) ∧ (#vr.4 < #k)) )
                                                  case case_1
                                                  solve( (¬(#vr.38 < #vr.4))  ∥
                                                         (∃ traffic_key #k.
                                                           (HandshakeComplete( $S, $A, 'server',
                                                                               traffic_key,
                                                                               <~session_id.3, 
                                                                                ~session_id.2>
                                                            ) @ #k)
                                                          ∧
                                                           (#k < #vr.4) ∧ (#vr.38 < #k)) )
                                                    case case_1
                                                    solve( (∀ #j. (K( ~b.2 ) @ #j) ⇒ ⊥)  ∥
                                                           (∃ #k.
                                                             (RevDHExp( ~b.2, ~session_id.3, $S
                                                              ) @ #k)) )
                                                      case case_1
                                                      solve( (#vr.4 = #vr.38)  ∥ (#vr.38 < #vr.4) )
                                                        case case_2
                                                        by contradiction /* from formulas */
                                                      qed
                                                    next
                                                      case case_2
                                                      solve( (#vr.4 = #vr.38)  ∥ (#vr.38 < #vr.4) )
                                                        case case_2
                                                        by contradiction /* from formulas */
                                                      qed
                                                    qed
                                                  next
                                                    case case_2
                                                    solve( (∀ #j. (K( ~b.2 ) @ #j) ⇒ ⊥)  ∥
                                                           (∃ #k.
                                                             (RevDHExp( ~b.2, ~session_id.3, $S
                                                              ) @ #k)) )
                                                      case case_1
                                                      solve( !Keys( <$S, $A, ~session_id.3, gb, 
                                                                     ga.2, traffic_key.1>
                                                             ) ▶₄ #k.1 )
                                                        case ServerHello
                                                        solve( !Pk( $A, pk(x) ) ▶₃ #k.1 )
                                                          case Register_pk
                                                          by solve( ServerFinished( <$S, $A, 
                                                                                     finished_key>,
                                                                                    <$S, $A, 
                                                                                     client_finished, 
                                                                                     ~session_id.2, 
                                                                                     ~session_id.1>
                                                                    ) ▶₆ #k.1 )
                                                        qed
                                                      qed
                                                    next
                                                      case case_2
                                                      solve( !Keys( <$S, $A, ~session_id.3, gb, 
                                                                     ga.2, traffic_key.1>
                                                             ) ▶₄ #k.1 )
                                                        case ServerHello
                                                        solve( !Pk( $A, pk(x) ) ▶₃ #k.1 )
                                                          case Register_pk
                                                          solve( DHExp( ~b.2, ~session_id.3, $S
                                                                 ) ▶₀ #k.2 )
                                                            case ServerHello
                                                            by solve( ServerFinished( <$S, $A, 
                                                                                       finished_key
                                                                                      >,
                                                                                      <$S, $A, 
                                                                                       client_finished, 
                                                                                       ~session_id.2, 
                                                                                       ~session_id.1
                                                                                      >
                                                                      ) ▶₆ #k.1 )
                                                          qed
                                                        qed
                                                      qed
                                                    qed
                                                  qed
                                                next
                                                  case case_2
                                                  solve( (∀ #j. (K( ~b.2 ) @ #j) ⇒ ⊥)  ∥
                                                         (∃ #k.
                                                           (RevDHExp( ~b.2, ~session_id.3, $S
                                                            ) @ #k)) )
                                                    case case_1
                                                    solve( !Pk( $A, pk(x) ) ▶₃ #k.1 )
                                                      case Register_pk
                                                      solve( !Keys( <$S, $A, ~session_id.3, gb, 
                                                                     ga.2, traffic_key.1>
                                                             ) ▶₄ #k.1 )
                                                        case ServerHello
                                                        by solve( ServerFinished( <$S, $A, 
                                                                                   finished_key>,
                                                                                  <$S, $A, 
                                                                                   client_finished, 
                                                                                   ~session_id.2, 
                                                                                   ~session_id.1>
                                                                  ) ▶₆ #k.1 )
                                                      qed
                                                    qed
                                                  next
                                                    case case_2
                                                    solve( !Pk( $A, pk(x) ) ▶₃ #k.1 )
                                                      case Register_pk
                                                      solve( !Keys( <$S, $A, ~session_id.3, gb, 
                                                                     ga.2, traffic_key.1>
                                                             ) ▶₄ #k.1 )
                                                        case ServerHello
                                                        by solve( ServerFinished( <$S, $A, 
                                                                                   finished_key>,
                                                                                  <$S, $A, 
                                                                                   client_finished, 
                                                                                   ~session_id.2, 
                                                                                   ~session_id.1>
                                                                  ) ▶₆ #k.1 )
                                                      qed
                                                    qed
                                                  qed
                                                qed
                                              next
                                                case ServerFinished_case_2
                                                solve( (¬(#vr.4 < #vr.38))  ∥
                                                       (∃ traffic_key #k.
                                                         (HandshakeComplete( $S, $A, 'server',
                                                                             traffic_key,
                                                                             <~session_id.2, 
                                                                              ~session_id.3>
                                                          ) @ #k)
                                                        ∧
                                                         (#k < #vr.38) ∧ (#vr.4 < #k)) )
                                                  case case_1
                                                  solve( (¬(#vr.38 < #vr.4))  ∥
                                                         (∃ traffic_key #k.
                                                           (HandshakeComplete( $S, $A, 'server',
                                                                               traffic_key,
                                                                               <~session_id.3, 
                                                                                ~session_id.2>
                                                            ) @ #k)
                                                          ∧
                                                           (#k < #vr.4) ∧ (#vr.38 < #k)) )
                                                    case case_1
                                                    solve( (∀ #j. (K( ~b.2 ) @ #j) ⇒ ⊥)  ∥
                                                           (∃ #k.
                                                             (RevDHExp( ~b.2, ~session_id.3, $S
                                                              ) @ #k)) )
                                                      case case_1
                                                      solve( (#vr.4 = #vr.38)  ∥ (#vr.38 < #vr.4) )
                                                        case case_2
                                                        by contradiction /* from formulas */
                                                      qed
                                                    next
                                                      case case_2
                                                      solve( (#vr.4 = #vr.38)  ∥ (#vr.38 < #vr.4) )
                                                        case case_2
                                                        by contradiction /* from formulas */
                                                      qed
                                                    qed
                                                  next
                                                    case case_2
                                                    solve( (∀ #j. (K( ~b.2 ) @ #j) ⇒ ⊥)  ∥
                                                           (∃ #k.
                                                             (RevDHExp( ~b.2, ~session_id.3, $S
                                                              ) @ #k)) )
                                                      case case_1
                                                      solve( !Pk( $A, pk(x) ) ▶₃ #k.1 )
                                                        case Register_pk
                                                        solve( !Keys( <$S, $A, ~session_id.3, gb, 
                                                                       ga.2, traffic_key.1>
                                                               ) ▶₄ #k.1 )
                                                          case ServerHello
                                                          by solve( ServerFinished( <$S, $A, 
                                                                                     finished_key>,
                                                                                    <$S, $A, 
                                                                                     client_finished, 
                                                                                     ~session_id.2, 
                                                                                     ~session_id.1>
                                                                    ) ▶₆ #k.1 )
                                                        qed
                                                      qed
                                                    next
                                                      case case_2
                                                      solve( !Pk( $A, pk(x) ) ▶₃ #k.1 )
                                                        case Register_pk
                                                        solve( !Keys( <$S, $A, ~session_id.3, gb, 
                                                                       ga.2, traffic_key.1>
                                                               ) ▶₄ #k.1 )
                                                          case ServerHello
                                                          by solve( ServerFinished( <$S, $A, 
                                                                                     finished_key>,
                                                                                    <$S, $A, 
                                                                                     client_finished, 
                                                                                     ~session_id.2, 
                                                                                     ~session_id.1>
                                                                    ) ▶₆ #k.1 )
                                                        qed
                                                      qed
                                                    qed
                                                  qed
                                                next
                                                  case case_2
                                                  solve( (∀ #j. (K( ~b.2 ) @ #j) ⇒ ⊥)  ∥
                                                         (∃ #k.
                                                           (RevDHExp( ~b.2, ~session_id.3, $S
                                                            ) @ #k)) )
                                                    case case_1
                                                    solve( !Pk( $A, pk(x) ) ▶₃ #k.1 )
                                                      case Register_pk
                                                      solve( !Keys( <$S, $A, ~session_id.3, gb, 
                                                                     ga.2, traffic_key.1>
                                                             ) ▶₄ #k.1 )
                                                        case ServerHello
                                                        by solve( ServerFinished( <$S, $A, 
                                                                                   finished_key>,
                                                                                  <$S, $A, 
                                                                                   client_finished, 
                                                                                   ~session_id.2, 
                                                                                   ~session_id.1>
                                                                  ) ▶₆ #k.1 )
                                                      qed
                                                    qed
                                                  next
                                                    case case_2
                                                    solve( !Pk( $A, pk(x) ) ▶₃ #k.1 )
                                                      case Register_pk
                                                      solve( !Keys( <$S, $A, ~session_id.3, gb, 
                                                                     ga.2, traffic_key.1>
                                                             ) ▶₄ #k.1 )
                                                        case ServerHello
                                                        by solve( ServerFinished( <$S, $A, 
                                                                                   finished_key>,
                                                                                  <$S, $A, 
                                                                                   client_finished, 
                                                                                   ~session_id.2, 
                                                                                   ~session_id.1>
                                                                  ) ▶₆ #k.1 )
                                                      qed
                                                    qed
                                                  qed
                                                qed
                                              qed
                                            next
                                              case AckNoAuth
                                              solve( St_ServerFinished( <$S, $A, session_id.3, 
                                                                         ClientHello, 
                                                                         HelloRetryRequest, 
                                                                         ClientHelloCookie, 
                                                                         ServerHello, 
                                                                         EncryptedExtensions, 
                                                                         ServerCertificate, 
                                                                         CertificateVerify, 
                                                                         ServerFinished>,
                                                                        <session_id.3, %next_seq, 
                                                                         %next_epoch, %rec_seq, 
                                                                         %rec_epoch.1>,
                                                                        <CHRecordNumbers, 
                                                                         CHCRecrodNumbers>
                                                     ) ▶₁ #k.1 )
                                                case ServerFinished_case_1
                                                solve( (¬(#vr.4 < #vr.38))  ∥
                                                       (∃ traffic_key #k.
                                                         (HandshakeComplete( $S, $A, 'server',
                                                                             traffic_key,
                                                                             <~session_id.2, 
                                                                              ~session_id.3>
                                                          ) @ #k)
                                                        ∧
                                                         (#k < #vr.38) ∧ (#vr.4 < #k)) )
                                                  case case_1
                                                  solve( (¬(#vr.38 < #vr.4))  ∥
                                                         (∃ traffic_key #k.
                                                           (HandshakeComplete( $S, $A, 'server',
                                                                               traffic_key,
                                                                               <~session_id.3, 
                                                                                ~session_id.2>
                                                            ) @ #k)
                                                          ∧
                                                           (#k < #vr.4) ∧ (#vr.38 < #k)) )
                                                    case case_1
                                                    solve( (∀ #j. (K( ~b.2 ) @ #j) ⇒ ⊥)  ∥
                                                           (∃ #k.
                                                             (RevDHExp( ~b.2, ~session_id.3, $S
                                                              ) @ #k)) )
                                                      case case_1
                                                      solve( (#vr.4 = #vr.38)  ∥ (#vr.38 < #vr.4) )
                                                        case case_2
                                                        by contradiction /* from formulas */
                                                      qed
                                                    next
                                                      case case_2
                                                      solve( (#vr.4 = #vr.38)  ∥ (#vr.38 < #vr.4) )
                                                        case case_2
                                                        by contradiction /* from formulas */
                                                      qed
                                                    qed
                                                  next
                                                    case case_2
                                                    solve( (∀ #j. (K( ~b.2 ) @ #j) ⇒ ⊥)  ∥
                                                           (∃ #k.
                                                             (RevDHExp( ~b.2, ~session_id.3, $S
                                                              ) @ #k)) )
                                                      case case_1
                                                      solve( !Keys( <$S, $A, ~session_id.3, gb, 
                                                                     ga.2, traffic_key.1>
                                                             ) ▶₂ #k.1 )
                                                        case ServerHello
                                                        by solve( ServerFinished( <$S, $A, 
                                                                                   finished_key>,
                                                                                  <$S, $A, 
                                                                                   client_finished, 
                                                                                   ~session_id.2, 
                                                                                   ~session_id.1>
                                                                  ) ▶₃ #k.1 )
                                                      qed
                                                    next
