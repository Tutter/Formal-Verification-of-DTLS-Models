lemma dh_challenge:
  all-traces
  "∀ actor1 actor2 random1 random2 g a b ga gb gab #i #j #r.
    ((((DHChal( actor1, random1, g, a, ga, gb, gab ) @ #i) ∧
       (DHChal( actor2, random2, g, b, ga, gb, gab ) @ #j)) ∧
      (¬(#i = #j))) ∧
     (K( gab ) @ #r)) ⇒
    ((((∃ #p. RevDHExp( a, random1, actor1 ) @ #p) ∨
       (∃ #q. RevDHExp( b, random2, actor2 ) @ #q)) ∨
      (∃ #s. Corrupt( actor1 ) @ #s)) ∨
     (∃ #t. Corrupt( actor2 ) @ #t))"
/*
guarded formula characterizing all counter-examples:
"∃ actor1 actor2 random1 random2 g a b ga gb gab #i #j #r.
  (DHChal( actor1, random1, g, a, ga, gb, gab ) @ #i) ∧
  (DHChal( actor2, random2, g, b, ga, gb, gab ) @ #j) ∧
  (K( gab ) @ #r)
 ∧
  (¬(#i = #j)) ∧
  (∀ #p. (RevDHExp( a, random1, actor1 ) @ #p) ⇒ ⊥) ∧
  (∀ #q. (RevDHExp( b, random2, actor2 ) @ #q) ⇒ ⊥) ∧
  (∀ #s. (Corrupt( actor1 ) @ #s) ⇒ ⊥) ∧
  (∀ #t. (Corrupt( actor2 ) @ #t) ⇒ ⊥)"
*/
by sorry

lemma matching_sessions:
  all-traces
  "∀ actor1 actor2 role1 role2 session_id1 session_id2
     HandshakeHistory key #i #j #k.
    ((((Running( actor1, role1, session_id1, HandshakeHistory, key
        ) @ #i) ∧
       (Running( actor2, role2, session_id2, HandshakeHistory, key
        ) @ #j)) ∧
      (¬(role1 = role2))) ∧
     (K( key ) @ #k)) ⇒
    ((((∃ random1 a #r.
         (RevDHExp( a, random1, actor1 ) @ #r) ∧ (#r < #i)) ∨
       (∃ random2 b #r.
         (RevDHExp( b, random2, actor2 ) @ #r) ∧ (#r < #j))) ∨
      (∃ #r. (Corrupt( actor1 ) @ #r) ∧ (#r < #i))) ∨
     (∃ #r. (Corrupt( actor2 ) @ #r) ∧ (#r < #j)))"
/*
guarded formula characterizing all counter-examples:
"∃ actor1 actor2 role1 role2 session_id1 session_id2
   HandshakeHistory key #i #j #k.
  (Running( actor1, role1, session_id1, HandshakeHistory, key
   ) @ #i) ∧
  (Running( actor2, role2, session_id2, HandshakeHistory, key
   ) @ #j) ∧
  (K( key ) @ #k)
 ∧
  (¬(role1 = role2)) ∧
  (∀ random1 a #r.
    (RevDHExp( a, random1, actor1 ) @ #r) ⇒ ¬(#r < #i)) ∧
  (∀ random2 b #r.
    (RevDHExp( b, random2, actor2 ) @ #r) ⇒ ¬(#r < #j)) ∧
  (∀ #r. (Corrupt( actor1 ) @ #r) ⇒ ¬(#r < #i)) ∧
  (∀ #r. (Corrupt( actor2 ) @ #r) ⇒ ¬(#r < #j))"
*/
by sorry

