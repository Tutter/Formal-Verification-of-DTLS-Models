rule (modulo E) Ack:
   [
   Fr( ~data ), Fr( ~len ),
   In( <$C, $S, handshakeCryptoHeader, 
        senc(<<'20', <rec_len, %rec_seq, %off, %frag>, client_finished>, 
              <'0', '0'>, '22'>,
             traffic_key)
       >
   ),
   !Keys( <$S, $C, session_id, gb, ga, traffic_key> ),
   St_ServerFinished( $S, $C, session_id,
                      <ClientHello, ServerHello, EncryptedExtensions, ServerFinished>,
                      <psk_id_1, psk_1>
   ),
   ServerFinished( <$S, $C, 
                    <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>, 
                    server_finished, session_id, <client_session_id, session_id>, 
                    finished_key>
   )
   ]
  --[
  Eq( client_finished, server_finished ), Reach( 'ACK' ),
  CommitAuth( $S, $C, 'server', session_id,
              <ClientHello, ServerHello, EncryptedExtensions, ServerFinished>,
              <psk_id_1, psk_1>
  ),
  HandshakeComplete( $S, $C, 'server', traffic_key,
                     <client_session_id, session_id>
  ),
  SessionKey( $S, $C, 'server', session_id, traffic_key, 'auth' ),
  Instance( session_id, $S, 'server' ),
  Send( $S, $C, 'ACK', session_id ),
  SendMsg( $S, $C, ~data, finished_key, ~len )
  ]->
   [
   Out( senc(<~data, ~len>, finished_key) ),
   !ServerSessionKey( $S, $C, session_id, finished_key )
   ]

  /*
  rule (modulo AC) Ack:
     [
     Fr( ~data ), Fr( ~len ),
     In( <$C, $S, <<'0', '0', '1'>, '0', '1', '1', '1', '0'>, 
          senc(<<'20', <rec_len, %rec_seq, %off, %frag>, client_finished>, 
                <'0', '0'>, '22'>,
               traffic_key)
         >
     ),
     !Keys( <$S, $C, session_id, gb, ga, traffic_key> ),
     St_ServerFinished( $S, $C, session_id,
                        <ClientHello, ServerHello, EncryptedExtensions, ServerFinished>,
                        <psk_id_1, psk_1>
     ),
     ServerFinished( <$S, $C, 
                      <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>, 
                      server_finished, session_id, <client_session_id, session_id>, 
                      finished_key>
     )
     ]
    --[
    Eq( client_finished, server_finished ), Reach( 'ACK' ),
    CommitAuth( $S, $C, 'server', session_id,
                <ClientHello, ServerHello, EncryptedExtensions, ServerFinished>,
                <psk_id_1, psk_1>
    ),
    HandshakeComplete( $S, $C, 'server', traffic_key,
                       <client_session_id, session_id>
    ),
    SessionKey( $S, $C, 'server', session_id, traffic_key, 'auth' ),
    Instance( session_id, $S, 'server' ),
    Send( $S, $C, 'ACK', session_id ),
    SendMsg( $S, $C, ~data, finished_key, ~len )
    ]->
     [
     Out( senc(<~data, ~len>, finished_key) ),
     !ServerSessionKey( $S, $C, session_id, finished_key )
     ]
  */

restriction Equal:
  "∀ x y #i. (Eq( x, y ) @ #i) ⇒ (x = y)"
  // safety formula

restriction Not_equal:
  "∀ x y #i. (Neq( x, y ) @ #i) ⇒ (¬(x = y))"
  // safety formula

lemma V1_Reachability_with_both_actors [use_induction]:
  exists-trace
  "∃ C S client_session_id server_session_id traffic_key #i #j #k #l.
    ((((((Start( C, S, 'client', client_session_id ) @ #i) ∧
         (Start( S, C, 'server', server_session_id ) @ #j)) ∧
        (HandshakeComplete( C, S, 'client', traffic_key,
                            <client_session_id, server_session_id>
         ) @ #k)) ∧
       (HandshakeComplete( S, C, 'server', traffic_key,
                           <client_session_id, server_session_id>
        ) @ #l)) ∧
      (¬(∃ #p. Corrupt( C ) @ #p))) ∧
     (¬(∃ #q. Corrupt( S ) @ #q))) ∧
    (¬(∃ #r. K( traffic_key ) @ #r))"
/*
guarded formula characterizing all satisfying traces:
"∃ C S client_session_id server_session_id traffic_key #i #j #k #l.
  (Start( C, S, 'client', client_session_id ) @ #i) ∧
  (Start( S, C, 'server', server_session_id ) @ #j) ∧
  (HandshakeComplete( C, S, 'client', traffic_key,
                      <client_session_id, server_session_id>
   ) @ #k) ∧
  (HandshakeComplete( S, C, 'server', traffic_key,
                      <client_session_id, server_session_id>
   ) @ #l)
 ∧
  (∀ #p. (Corrupt( C ) @ #p) ⇒ ⊥) ∧
  (∀ #q. (Corrupt( S ) @ #q) ⇒ ⊥) ∧
  (∀ #r. (K( traffic_key ) @ #r) ⇒ ⊥)"
*/
by sorry

lemma R6_only_one_start_per_tid [reuse]:
  all-traces
  "∀ session_id actor1 actor2 peer1 peer2 role1 role2 #i #j.
    ((Start( actor1, peer1, role1, session_id ) @ #i) ∧
     (Start( actor2, peer2, role2, session_id ) @ #j)) ⇒
    (#i = #j)"
/*
guarded formula characterizing all counter-examples:
"∃ session_id actor1 actor2 peer1 peer2 role1 role2 #i #j.
  (Start( actor1, peer1, role1, session_id ) @ #i) ∧
  (Start( actor2, peer2, role2, session_id ) @ #j)
 ∧
  ¬(#i = #j)"
*/
by sorry

lemma R8_one_dh_per_x [reuse]:
  all-traces
  "∀ tid tid2 x actor actor2 #i #j.
    ((DH( x, tid, actor ) @ #i) ∧ (DH( x, tid2, actor2 ) @ #j)) ⇒
    (#i = #j)"
/*
guarded formula characterizing all counter-examples:
"∃ tid tid2 x actor actor2 #i #j.
  (DH( x, tid, actor ) @ #i) ∧ (DH( x, tid2, actor2 ) @ #j)
 ∧
  ¬(#i = #j)"
*/
by sorry

lemma R7_dh_invariant [reuse]:
  all-traces
  "∀ tid actor x #i.
    (RevDHExp( x, tid, actor ) @ #i) ⇒
    (∃ #j. (DH( x, tid, actor ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ tid actor x #i.
  (RevDHExp( x, tid, actor ) @ #i)
 ∧
  ∀ #j. (DH( x, tid, actor ) @ #j) ⇒ ¬(#j < #i)"
*/
by sorry

lemma R5_Session_id_invariant [reuse]:
  all-traces
  "∀ session_id actor role #i.
    (Instance( session_id, actor, role ) @ #i) ⇒
    (∃ peer #j.
      (Start( actor, peer, role, session_id ) @ #j) ∧ (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"∃ session_id actor role #i.
  (Instance( session_id, actor, role ) @ #i)
 ∧
  ∀ peer #j.
   (Start( actor, peer, role, session_id ) @ #j) ⇒ ¬(#j < #i)"
*/
by sorry

lemma dh_challenge [reuse]:
  all-traces
  "∀ actor1 actor2 random1 random2 g a b ga gb gab #i #j #r.
    ((((DHChal( actor1, random1, g, a, ga, gb, gab ) @ #i) ∧
       (DHChal( actor2, random2, g, b, ga, gb, gab ) @ #j)) ∧
      (¬(#i = #j))) ∧
     (K( gab ) @ #r)) ⇒
    ((((∃ #p. RevDHExp( a, random1, actor1 ) @ #p) ∨
       (∃ #q. RevDHExp( b, random2, actor2 ) @ #q)) ∨
      (∃ #s. Corrupt( actor1 ) @ #s)) ∨
     (∃ #t. Corrupt( actor2 ) @ #t))"
/*
guarded formula characterizing all counter-examples:
"∃ actor1 actor2 random1 random2 g a b ga gb gab #i #j #r.
  (DHChal( actor1, random1, g, a, ga, gb, gab ) @ #i) ∧
  (DHChal( actor2, random2, g, b, ga, gb, gab ) @ #j) ∧
  (K( gab ) @ #r)
 ∧
  (¬(#i = #j)) ∧
  (∀ #p. (RevDHExp( a, random1, actor1 ) @ #p) ⇒ ⊥) ∧
  (∀ #q. (RevDHExp( b, random2, actor2 ) @ #q) ⇒ ⊥) ∧
  (∀ #s. (Corrupt( actor1 ) @ #s) ⇒ ⊥) ∧
  (∀ #t. (Corrupt( actor2 ) @ #t) ⇒ ⊥)"
*/
by sorry

restriction R1_Only_one_session_per_pair_at_a_time:
  "∀ actor1 actor2 role session_id1 session_id2 #i #j.
    (((Start( actor1, actor2, role, session_id1 ) @ #i) ∧
      (Start( actor1, actor2, role, session_id2 ) @ #j)) ∧
     (#i < #j)) ⇒
    (∃ traffic_key #k.
      ((HandshakeComplete( actor1, actor2, role, traffic_key,
                           <session_id1, session_id2>
        ) @ #k) ∧
       (#k < #j)) ∧
      (#i < #k))"

restriction R2_Dont_essablish_session_with_self:
  "∀ actor1 actor2 role session_id #i.
    ((Start( actor1, actor2, role, session_id ) @ #i) ∧
     (actor1 = actor2)) ⇒
    (⊥)"
  // safety formula

restriction R3_Dont_resend_messages:
  "∀ actor1 actor2 msg_type session_id #i #j.
    ((Send( actor1, actor2, msg_type, session_id ) @ #i) ∧
     (Send( actor1, actor2, msg_type, session_id ) @ #j)) ⇒
    (#i = #j)"
  // safety formula

restriction R9_rev_dh_before_hs:
  "∀ tid actor role hs session_id key x #i #j.
    ((Running( actor, role, session_id, hs, key ) @ #j) ∧
     (RevDHExp( x, tid, actor ) @ #i)) ⇒
    (#i < #j)"
  // safety formula

lemma H1_Establishing_the_same_session_keys:
  all-traces
  "∀ C S client_session_id server_session_id keyC keyS #i #j.
    ((((HandshakeComplete( C, S, 'client', keyC,
                           <client_session_id, server_session_id>
        ) @ #i) ∧
       (HandshakeComplete( S, C, 'server', keyS,
                           <client_session_id, server_session_id>
        ) @ #j)) ∧
      (¬(∃ #p. Corrupt( C ) @ #p))) ∧
     (¬(∃ #q. Corrupt( S ) @ #q))) ⇒
    (keyC = keyS)"
/*
guarded formula characterizing all counter-examples:
"∃ C S client_session_id server_session_id keyC keyS #i #j.
  (HandshakeComplete( C, S, 'client', keyC,
                      <client_session_id, server_session_id>
   ) @ #i) ∧
  (HandshakeComplete( S, C, 'server', keyS,
                      <client_session_id, server_session_id>
   ) @ #j)
 ∧
  (∀ #p. (Corrupt( C ) @ #p) ⇒ ⊥) ∧
  (∀ #q. (Corrupt( S ) @ #q) ⇒ ⊥) ∧
  (¬(keyC = keyS))"
*/
simplify
solve( HandshakeComplete( C, S, 'client', keyC,
                          <client_session_id, server_session_id>
       ) @ #i )
  case ClientFinished
  solve( St_ClientHello( <$C, $S, <a, psk_1>, client_session_id>,
                         ClientHello,
                         <client_session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
         ) ▶₁ #i )
    case ClientHelloPsk
    solve( HandshakeComplete( $S, $C, 'server', keyS,
                              <~session_id, server_session_id>
           ) @ #j.1 )
      case Ack
      solve( !Keys( <$S, $C, server_session_id, gb.1, ga, keyS>
             ) ▶₃ #j.1 )
        case ServerHello
        solve( (¬(#j < #vr.1))  ∥
               (∃ traffic_key #k.
                 (HandshakeComplete( $C, $S, 'client', traffic_key,
                                     <~session_id, ~session_id.2>
                  ) @ #k)
                ∧
                 (#k < #vr.1) ∧ (#j < #k)) )
          case case_1
          solve( (¬(#vr.1 < #j))  ∥
                 (∃ traffic_key #k.
                   (HandshakeComplete( $C, $S, 'client', traffic_key,
                                       <~session_id.2, ~session_id>
                    ) @ #k)
                  ∧
                   (#k < #j) ∧ (#vr.1 < #k)) )
            case case_1
            solve( (#j = #vr.1)  ∥ (#vr.1 < #j) )
              case case_1
              solve( St_ServerFinished( $S, $C, ~session_id.1,
                                        <ClientHello, ServerHello, EncryptedExtensions, 
                                         ServerFinished>,
                                        <psk_id_1.2, psk_1.1>
                     ) ▶₄ #j.1 )
                case ServerFinished
                solve( ServerFinished( <$S, $C, 
                                        <~session_id.1, %next_seq, %next_epoch, %rec_seq, %rec_epoch
                                        >, 
                                        client_finished, ~session_id.1, 
                                        <~session_id, ~session_id.1>, finished_key>
                       ) ▶₅ #j.1 )
                  case ServerFinished
                  solve( Start( $C, peer, 'client', ~session_id ) @ #j )
                    case ClientHelloPsk
                    solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.2 )
                      case ServerHello
                      solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.2 )
                        case ServerHello
                        solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.2 )
                          case ServerHello
                          solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.2 )
                            case ServerHello
                            solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.2 )
                              case ServerHello
                              solve( !KU( senc(<
                                                <'8', <lenEE, %1, %1, %1>, '13', 
                                                 'encryptedExtensions'>, 
                                                '0', '22'>,
                                               <z, ~psk_1>)
                                     ) @ #vk.72 )
                                case EncryptedExtensions
                                by contradiction /* from formulas */
                              next
                                case c_senc
                                by solve( !KU( ~psk_1 ) @ #vk.92 )
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            next
              case case_2
              by contradiction /* from formulas */
            qed
          next
            case case_2
            solve( St_ServerFinished( $S, $C, ~session_id.1,
                                      <ClientHello, ServerHello, EncryptedExtensions, ServerFinished
                                      >,
                                      <psk_id_1.3, psk_1.2>
                   ) ▶₄ #j.1 )
              case ServerFinished
              solve( ServerFinished( <$S, $C, 
                                      <~session_id.1, %next_seq, %next_epoch, %rec_seq, %rec_epoch
                                      >, 
                                      client_finished, ~session_id.1, <~session_id, ~session_id.1>, 
                                      finished_key>
                     ) ▶₅ #j.1 )
                case ServerFinished
                solve( Start( $C, peer, 'client', ~session_id ) @ #j )
                  case ClientHelloPsk
                  solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.2 )
                    case ServerHello
                    solve( HandshakeComplete( $C, $S, 'client', traffic_key,
                                              <~session_id.2, ~session_id>
                           ) @ #k )
                      case ClientFinished
                      by contradiction /* cyclic */
                    qed
                  qed
                qed
              qed
            qed
          qed
        next
          case case_2
          solve( St_ServerFinished( $S, $C, ~session_id.1,
                                    <ClientHello, ServerHello, EncryptedExtensions, ServerFinished>,
                                    <psk_id_1.3, psk_1.2>
                 ) ▶₄ #j.1 )
            case ServerFinished
            solve( ServerFinished( <$S, $C, 
                                    <~session_id.1, %next_seq, %next_epoch, %rec_seq, %rec_epoch>, 
                                    client_finished, ~session_id.1, <~session_id, ~session_id.1>, 
                                    finished_key>
                   ) ▶₅ #j.1 )
              case ServerFinished
              solve( Start( $C, peer, 'client', ~session_id ) @ #j )
                case ClientHelloPsk
                solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.2 )
                  case ServerHello
                  solve( HandshakeComplete( $C, $S, 'client', traffic_key,
                                            <~session_id, ~session_id.2>
                         ) @ #k )
                    case ClientFinished
                    by contradiction /* cyclic */
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma H2_Session_key_secrecy:
  all-traces
  "∀ actor peer role session_id key #i #j.
    ((SessionKey( actor, peer, role, session_id, key, 'auth' ) @ #i) ∧
     (K( key ) @ #j)) ⇒
    ((∃ #p. Corrupt( actor ) @ #p) ∨ (∃ #q. Corrupt( peer ) @ #q))"
/*
guarded formula characterizing all counter-examples:
"∃ actor peer role session_id key #i #j.
  (SessionKey( actor, peer, role, session_id, key, 'auth' ) @ #i) ∧
  (K( key ) @ #j)
 ∧
  (∀ #p. (Corrupt( actor ) @ #p) ⇒ ⊥) ∧
  (∀ #q. (Corrupt( peer ) @ #q) ⇒ ⊥)"
*/
simplify
solve( SessionKey( actor, peer, role, session_id, key, 'auth'
       ) @ #i )
  case Ack
  solve( !Keys( <$S, $C, session_id, gb, ga, key> ) ▶₃ #i )
    case ServerHello
    solve( St_ServerFinished( $S, $C, ~session_id,
                              <ClientHello, ServerHello, EncryptedExtensions, ServerFinished>,
                              <psk_id_1, psk_1.1>
           ) ▶₄ #i )
      case ServerFinished
      solve( ServerFinished( <$S, $C, 
                              <~session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>, 
                              client_finished, ~session_id, <client_session_id.1, ~session_id>, 
                              finished_key>
             ) ▶₅ #i )
        case ServerFinished
        solve( Start( $S, peer, 'server', ~session_id ) @ #j.1 )
          case ServerHello
          solve( Start( $S, peer, 'server', ~session_id ) @ #j.1 )
            case ServerHello
            solve( Start( $S, peer, 'server', ~session_id ) @ #j.1 )
              case ServerHello
              solve( Start( $S, peer, 'server', ~session_id ) @ #j.1 )
                case ServerHello
                solve( Start( $S, peer, 'server', ~session_id ) @ #j.1 )
                  case ServerHello
                  by solve( !KU( ~psk_1 ) @ #vk.51 )
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
next
  case ClientFinished
  solve( St_ClientHello( <$C, $S, <a, psk_1>, session_id>,
                         ClientHello,
                         <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
         ) ▶₁ #i )
    case ClientHelloPsk
    solve( Start( $C, peer, 'client', ~session_id ) @ #j.1 )
      case ClientHelloPsk
      by solve( !KU( ~psk_1 ) @ #vk.55 )
    qed
  qed
qed

lemma H3_Authentication:
  all-traces
  "∀ actor1 actor2 role1 session_id1 HandshakeHistory key #i.
    (((CommitAuth( actor1, actor2, role1, session_id1,
                   HandshakeHistory, key
       ) @ #i) ∧
      (¬(∃ #p. Corrupt( actor1 ) @ #p))) ∧
     (¬(∃ #q. Corrupt( actor2 ) @ #q))) ⇒
    (∃ role2 session_id2 #r.
      RunningAuth( actor2, role2, session_id2, HandshakeHistory, key
      ) @ #r)"
/*
guarded formula characterizing all counter-examples:
"∃ actor1 actor2 role1 session_id1 HandshakeHistory key #i.
  (CommitAuth( actor1, actor2, role1, session_id1, HandshakeHistory,
               key
   ) @ #i)
 ∧
  (∀ #p. (Corrupt( actor1 ) @ #p) ⇒ ⊥) ∧
  (∀ #q. (Corrupt( actor2 ) @ #q) ⇒ ⊥) ∧
  (∀ role2 session_id2 #r.
    (RunningAuth( actor2, role2, session_id2, HandshakeHistory, key
     ) @ #r)
   ⇒
    ⊥)"
*/
simplify
solve( CommitAuth( actor1, actor2, role1, session_id1,
                   HandshakeHistory, key
       ) @ #i )
  case Ack
  solve( !Keys( <$S, $C, session_id1, gb, ga, traffic_key> ) ▶₃ #i )
    case ServerHello
    solve( St_ServerFinished( $S, $C, ~session_id,
                              <ClientHello, ServerHello, EncryptedExtensions, ServerFinished>,
                              <psk_id_1, psk_1.1>
           ) ▶₄ #i )
      case ServerFinished
      solve( ServerFinished( <$S, $C, 
                              <~session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>, 
                              client_finished, ~session_id, <client_session_id.1, ~session_id>, 
                              finished_key>
             ) ▶₅ #i )
        case ServerFinished
        solve( Start( $S, peer, 'server', ~session_id ) @ #j )
          case ServerHello
          solve( Start( $S, peer, 'server', ~session_id ) @ #j )
            case ServerHello
            solve( Start( $S, peer, 'server', ~session_id ) @ #j )
              case ServerHello
              solve( Start( $S, peer, 'server', ~session_id ) @ #j )
                case ServerHello
                solve( Start( $S, peer, 'server', ~session_id ) @ #j )
                  case ServerHello
                  solve( !KU( senc(<
                                    <'20', <rec_len, %1, %off, %frag>, 
                                     hmac(<HKDFExpand(<<z, ~psk_1>, 'finished', 'Hash_length'>), 
                                           h1(<
                                               <'1', <'254', '253'>, client_session_id, 
                                                'CipherSuits', '41', ~psk_id_1, '45', '1', '51', 
                                                'g', ga>, 
                                               <'2', <'254', '253'>, ~session_id, 'CipherSuits', 
                                                '41', <~psk_id_1, ~obfuscated_ticket_age>, '51', 
                                                'g', 'g'^~b>, 
                                               '8', '13', 'encryptedExtensions'>)
                                          >)
                                    >, 
                                    <'0', '0'>, '22'>,
                                   <z, ~psk_1>)
                         ) @ #vk.29 )
                    case ClientFinished
                    by contradiction /* from formulas */
                  next
                    case c_senc
                    by solve( !KU( ~psk_1 ) @ #vk.64 )
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
next
  case ClientFinished
  solve( St_ClientHello( <$C, $S, <a, psk_1>, session_id1>,
                         ClientHello,
                         <session_id1, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
         ) ▶₁ #i )
    case ClientHelloPsk
    solve( Start( $C, peer, 'client', ~session_id ) @ #j )
      case ClientHelloPsk
      solve( !KU( senc(<
                        <'8', <lenEE, %1, %1, %1>, '13', 'encryptedExtensions'>, '0', '22'
                       >,
                       <z, ~psk_1>)
             ) @ #vk.51 )
        case EncryptedExtensions
        solve( Start( $S, peer, 'server', ~session_id.1 ) @ #vr.4 )
          case ServerHello
          solve( !KU( senc(<
                            <'20', <lenSF, (%1%+%1), %1, %1>, 
                             hmac(<HKDFExpand(<<z, ~psk_1>, 'finished', 'Hash_length'>), 
                                   h1(<
                                       <'1', <'254', '253'>, ~session_id, 'CipherSuits', '41', 
                                        ~psk_id_1, '45', '1', '51', 'g', 'g'^~a>, 
                                       <'2', <'254', '253'>, server_session_id, 'CipherSuits', 
                                        '41', <psk_id_1.1, obfuscated_ticket_age>, '51', 'g', gb>, 
                                       '8', '13', 'encryptedExtensions'>)
                                  >)
                            >, 
                            '0', '22'>,
                           <z, ~psk_1>)
                 ) @ #vk.69 )
            case ServerFinished
            by contradiction /* from formulas */
          next
            case c_senc
            by solve( !KU( ~psk_1 ) @ #vk.88 )
          qed
        qed
      next
        case c_senc
        by solve( !KU( ~psk_1 ) @ #vk.65 )
      qed
    qed
  qed
qed

lemma H4_Unique_session_keys:
  all-traces
  "∀ actor1 actor2 peer1 peer2 role key session_id1 session_id2 auth1
     auth2 #i #j.
    ((SessionKey( actor1, peer1, role, session_id1, key, auth1
      ) @ #i) ∧
     (SessionKey( actor2, peer2, role, session_id2, key, auth2
      ) @ #j)) ⇒
    (((((#i = #j) ∨ (∃ #p. Corrupt( actor1 ) @ #p)) ∨
       (∃ #q. Corrupt( actor2 ) @ #q)) ∨
      (∃ #p. Corrupt( peer1 ) @ #p)) ∨
     (∃ #q. Corrupt( peer2 ) @ #q))"
/*
guarded formula characterizing all counter-examples:
"∃ actor1 actor2 peer1 peer2 role key session_id1 session_id2 auth1
   auth2 #i #j.
  (SessionKey( actor1, peer1, role, session_id1, key, auth1 ) @ #i) ∧
  (SessionKey( actor2, peer2, role, session_id2, key, auth2 ) @ #j)
 ∧
  (¬(#i = #j)) ∧
  (∀ #p. (Corrupt( actor1 ) @ #p) ⇒ ⊥) ∧
  (∀ #q. (Corrupt( actor2 ) @ #q) ⇒ ⊥) ∧
  (∀ #p. (Corrupt( peer1 ) @ #p) ⇒ ⊥) ∧
  (∀ #q. (Corrupt( peer2 ) @ #q) ⇒ ⊥)"
*/
simplify
solve( (#i < #j)  ∥ (#j < #i) )
  case case_1
  solve( SessionKey( actor1, peer1, role, session_id1, key, auth1
         ) @ #i )
    case Ack
    solve( !Keys( <$S, $C, session_id1, gb, ga, key> ) ▶₃ #i )
      case ServerHello
      solve( St_ServerFinished( $S, $C, ~session_id,
                                <ClientHello, ServerHello, EncryptedExtensions, ServerFinished>,
                                <psk_id_1, psk_1.1>
             ) ▶₄ #i )
        case ServerFinished
        solve( ServerFinished( <$S, $C, 
                                <~session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>, 
                                client_finished, ~session_id, <client_session_id.1, ~session_id>, 
                                finished_key>
               ) ▶₅ #i )
          case ServerFinished
          solve( SessionKey( actor2, peer2, 'server', session_id2,
                             <z, ~psk_1>, auth2
                 ) @ #j.1 )
            case Ack
            solve( !Keys( <$S.1, $C.1, session_id2, gb, ga.1, z, ~psk_1>
                   ) ▶₃ #j.1 )
              case ServerHello
              by contradiction /* cyclic */
            qed
          qed
        qed
      qed
    qed
  next
    case ClientFinished
    solve( St_ClientHello( <$C, $S, <a, psk_1>, session_id1>,
                           ClientHello,
                           <session_id1, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
           ) ▶₁ #i )
      case ClientHelloPsk
      solve( SessionKey( actor2, peer2, 'client', session_id2,
                         <z, ~psk_1>, auth2
             ) @ #j.1 )
        case ClientFinished
        solve( St_ClientHello( <$C.1, $S.1, <a.1, ~psk_1>, session_id2>,
                               ClientHello,
                               <session_id2, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
               ) ▶₁ #j.1 )
          case ClientHelloPsk
          by contradiction /* cyclic */
        qed
      qed
    qed
  qed
next
  case case_2
  solve( SessionKey( actor1, peer1, role, session_id1, key, auth1
         ) @ #i )
    case Ack
    solve( !Keys( <$S, $C, session_id1, gb, ga, key> ) ▶₃ #i )
      case ServerHello
      solve( St_ServerFinished( $S, $C, ~session_id,
                                <ClientHello, ServerHello, EncryptedExtensions, ServerFinished>,
                                <psk_id_1, psk_1.1>
             ) ▶₄ #i )
        case ServerFinished
        solve( ServerFinished( <$S, $C, 
                                <~session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>, 
                                client_finished, ~session_id, <client_session_id.1, ~session_id>, 
                                finished_key>
               ) ▶₅ #i )
          case ServerFinished
          solve( SessionKey( actor2, peer2, 'server', session_id2,
                             <z, ~psk_1>, auth2
                 ) @ #j.1 )
            case Ack
            solve( !Keys( <$S.1, $C.1, session_id2, gb, ga.1, z, ~psk_1>
                   ) ▶₃ #j.1 )
              case ServerHello
              by contradiction /* cyclic */
            qed
          qed
        qed
      qed
    qed
  next
    case ClientFinished
    solve( St_ClientHello( <$C, $S, <a, psk_1>, session_id1>,
                           ClientHello,
                           <session_id1, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
           ) ▶₁ #i )
      case ClientHelloPsk
      solve( SessionKey( actor2, peer2, 'client', session_id2,
                         <z, ~psk_1>, auth2
             ) @ #j.1 )
        case ClientFinished
        solve( St_ClientHello( <$C.1, $S.1, <a.1, ~psk_1>, session_id2>,
                               ClientHello,
                               <session_id2, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
               ) ▶₁ #j.1 )
          case ClientHelloPsk
          by contradiction /* cyclic */
        qed
      qed
    qed
  qed
qed

lemma H6_Forward_secrecy:
  all-traces
  "∀ C S key nonce #i #j.
    ((((HandshakeComplete( C, S, 'client', key, nonce ) @ #i) ∧
       (HandshakeComplete( S, C, 'server', key, nonce ) @ #j)) ∧
      ((∃ #p. (Corrupt( C ) @ #p) ∧ (#j < #p)) ∨
       (∃ #q. (Corrupt( S ) @ #q) ∧ (#j < #q)))) ∧
     (¬(∃ #k. (K( key ) @ #k) ∧ (#k < #j)))) ⇒
    (¬(∃ #k. K( key ) @ #k))"
/*
guarded formula characterizing all counter-examples:
"∃ C S key nonce #i #j.
  (HandshakeComplete( C, S, 'client', key, nonce ) @ #i) ∧
  (HandshakeComplete( S, C, 'server', key, nonce ) @ #j)
 ∧
  (((∃ #p. (Corrupt( C ) @ #p) ∧ #j < #p) ∨
    (∃ #q. (Corrupt( S ) @ #q) ∧ #j < #q))) ∧
  (∀ #k. (K( key ) @ #k) ⇒ ¬(#k < #j)) ∧
  (∃ #k. (K( key ) @ #k))"
*/
simplify
solve( (∃ #p. (Corrupt( C ) @ #p) ∧ #j < #p)  ∥
       (∃ #q. (Corrupt( S ) @ #q) ∧ #j < #q) )
  case case_1
  solve( (#k = #j)  ∥ (#j < #k) )
    case case_1
    solve( DHExp( ~x, ~tid, $A ) ▶₀ #p )
      case ClientHelloPsk
      solve( HandshakeComplete( $A, S.1, 'client', key, nonce ) @ #i )
        case ClientFinished
        solve( St_ClientHello( <$A, $S, <a, psk_1>, session_id>,
                               ClientHello,
                               <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
               ) ▶₁ #i )
          case ClientHelloPsk
          by solve( HandshakeComplete( $S, $A, 'server', <z, ~psk_1>,
                                       <~session_id, server_session_id>
                    ) @ #j )
        qed
      qed
    next
      case ServerHello
      solve( HandshakeComplete( $A, S, 'client', key, nonce ) @ #i )
        case ClientFinished
        solve( St_ClientHello( <$A, $S, <a, psk_1>, session_id>,
                               ClientHello,
                               <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
               ) ▶₁ #i )
          case ClientHelloPsk
          by solve( HandshakeComplete( $S, $A, 'server', <z, ~psk_1>,
                                       <~session_id, server_session_id>
                    ) @ #j )
        qed
      qed
    qed
  next
    case case_2
    solve( DHExp( ~x, ~tid, $A ) ▶₀ #p )
      case ClientHelloPsk
      solve( HandshakeComplete( $A, S.1, 'client', key, nonce ) @ #i )
        case ClientFinished
        solve( St_ClientHello( <$A, $S, <a, psk_1>, session_id>,
                               ClientHello,
                               <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
               ) ▶₁ #i )
          case ClientHelloPsk
          solve( HandshakeComplete( $S, $A, 'server', <z, ~psk_1>,
                                    <~session_id, server_session_id>
                 ) @ #j.2 )
            case Ack
            solve( !Keys( <$S, $A, server_session_id, gb.1, ga, z, ~psk_1>
                   ) ▶₃ #j.2 )
              case ServerHello
              solve( St_ServerFinished( $S, $A, ~session_id.1,
                                        <ClientHello, ServerHello, EncryptedExtensions, 
                                         ServerFinished>,
                                        <psk_id_1.3, psk_1.2>
                     ) ▶₄ #j.2 )
                case ServerFinished
                solve( ServerFinished( <$S, $A, 
                                        <~session_id.1, %next_seq, %next_epoch, %rec_seq, %rec_epoch
                                        >, 
                                        client_finished, ~session_id.1, 
                                        <~session_id, ~session_id.1>, finished_key>
                       ) ▶₅ #j.2 )
                  case ServerFinished
                  solve( DH( ~x, ~tid, $A ) @ #j )
                    case ClientHelloPsk
                    solve( Start( $A, peer, 'client', ~session_id ) @ #j.1 )
                      case ClientHelloPsk
                      solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.3 )
                        case ServerHello
                        solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.3 )
                          case ServerHello
                          solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.3 )
                            case ServerHello
                            solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.3 )
                              case ServerHello
                              solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.3 )
                                case ServerHello
                                by solve( !KU( ~psk_1 ) @ #vk.76 )
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    next
      case ServerHello
      solve( HandshakeComplete( $A, S, 'client', key, nonce ) @ #i )
        case ClientFinished
        solve( St_ClientHello( <$A, $S, <a, psk_1>, session_id>,
                               ClientHello,
                               <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
               ) ▶₁ #i )
          case ClientHelloPsk
          solve( HandshakeComplete( $S, $A, 'server', <z, ~psk_1>,
                                    <~session_id, server_session_id>
                 ) @ #j.2 )
            case Ack
            solve( !Keys( <$S, $A, server_session_id, gb.1, ga.1, z, ~psk_1>
                   ) ▶₃ #j.2 )
              case ServerHello
              solve( St_ServerFinished( $S, $A, ~session_id.1,
                                        <ClientHello, ServerHello, EncryptedExtensions, 
                                         ServerFinished>,
                                        <psk_id_1.3, psk_1.2>
                     ) ▶₄ #j.2 )
                case ServerFinished
                solve( ServerFinished( <$S, $A, 
                                        <~session_id.1, %next_seq, %next_epoch, %rec_seq, %rec_epoch
                                        >, 
                                        client_finished, ~session_id.1, 
                                        <~session_id, ~session_id.1>, finished_key>
                       ) ▶₅ #j.2 )
                  case ServerFinished
                  solve( DH( ~x, ~tid, $A ) @ #j )
                    case ServerHello
                    solve( Start( $A, peer, 'client', ~session_id ) @ #j.1 )
                      case ClientHelloPsk
                      solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.3 )
                        case ServerHello
                        solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.3 )
                          case ServerHello
                          solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.3 )
                            case ServerHello
                            solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.3 )
                              case ServerHello
                              solve( Start( $S, peer, 'server', ~session_id.1 ) @ #j.3 )
                                case ServerHello
                                by solve( !KU( ~psk_1 ) @ #vk.100 )
                              qed
                            qed
                          qed
                        qed
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
next
  case case_2
  solve( (#k = #j)  ∥ (#j < #k) )
    case case_1
    solve( DHExp( ~x, ~tid, $A ) ▶₀ #q )
      case ClientHelloPsk
      solve( HandshakeComplete( C, $A, 'client', key, nonce ) @ #i )
        case ClientFinished
