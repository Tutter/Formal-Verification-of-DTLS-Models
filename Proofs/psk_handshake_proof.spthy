theory psk_handshake begin

// Function signature and definition of the equational theory E

builtins: diffie-hellman, natural-numbers
functions: HKDFExpand/1, adec/2, aenc/2, fst/1, h/1, h1/1, hmac/1,
           pair/2, pk/1, sdec/2, senc/2, sign/2, snd/1, true/0, verify/3
equations:
    adec(aenc(x.1, pk(x.2)), x.2) = x.1,
    fst(<x.1, x.2>) = x.1,
    sdec(senc(x.1, x.2), x.2) = x.1,
    snd(<x.1, x.2>) = x.2,
    verify(sign(x.1, x.2), x.1, pk(x.2)) = true

















macros:
    handshakeCryptoHeader( ) = pair(pair('0',pair('0','1')),pair('0',pair('1',pair('1',pair('1','0')))))
    protocolVersion( ) = pair('254','253')

rule (modulo E) Reveal_DHExp:
   [ DHExp( ~x, ~tid, $A ) ]
  --[ RevDHExp( ~x, ~tid, $A ), Corrupt( $A ) ]->
   [ Out( ~x ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Secure_Chan:
   [ S_Out( m ) ] --> [ S_In( m ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ClientHelloPsk:
   [
   Fr( ~psk_id_1 ), Fr( ~psk_1 ), Fr( ~session_id ), Fr( ~a ),
   Fr( ~msg_len )
   ]
  --[
  DH( ~a, ~session_id, $C ), Start( $C, $S, 'client', ~session_id )
  ]->
   [
   S_Out( <$C, $S, ~psk_id_1, ~psk_1> ),
   Out( <$C, $S, '22', %1, %1, ~msg_len, '1', <~msg_len, %1, %1, %1>, 
         protocolVersion, ~session_id, 'CipherSuits', '41', ~psk_id_1, 
         '45', '1', '51', 'g', 'g'^~a>
   ),
   St_ClientHello( <$C, $S, <~a, ~psk_1>, ~session_id>,
                   <'1', protocolVersion, ~session_id, 'CipherSuits', '41', 
                    ~psk_id_1, '45', '1', '51', 'g', 'g'^~a>,
                   <~session_id, %1, (%1%+%1), %1, %1>
   ),
   DHExp( ~a, ~session_id, $C )
   ]

  /*
  rule (modulo AC) ClientHelloPsk:
     [
     Fr( ~psk_id_1 ), Fr( ~psk_1 ), Fr( ~session_id ), Fr( ~a ),
     Fr( ~msg_len )
     ]
    --[
    DH( ~a, ~session_id, $C ), Start( $C, $S, 'client', ~session_id )
    ]->
     [
     S_Out( <$C, $S, ~psk_id_1, ~psk_1> ),
     Out( <$C, $S, '22', %1, %1, ~msg_len, '1', <~msg_len, %1, %1, %1>, 
           <'254', '253'>, ~session_id, 'CipherSuits', '41', ~psk_id_1, '45', 
           '1', '51', 'g', 'g'^~a>
     ),
     St_ClientHello( <$C, $S, <~a, ~psk_1>, ~session_id>,
                     <'1', <'254', '253'>, ~session_id, 'CipherSuits', '41', ~psk_id_1, 
                      '45', '1', '51', 'g', 'g'^~a>,
                     <~session_id, %1, (%1%+%1), %1, %1>
     ),
     DHExp( ~a, ~session_id, $C )
     ]
  */

rule (modulo E) ServerHello:
   [
   Fr( ~obfuscated_ticket_age ), Fr( ~session_id ), Fr( ~b ),
   Fr( ~msg_len ), S_In( <$C, $S, psk_id_1, psk_1> ),
   In( <$C, $S, '22', %1, %1, lenCH, '1', <lenCH, %1, %1, %1>, 
        protocolVersion, client_session_id, 'CipherSuits', '41', psk_id_1, 
        '45', '1', '51', 'g', ga>
   )
   ]
  --[
  Neq( 'g', ga ), Neq( ga, ga^~b ),
  DHChal( $S, ~session_id, 'g', ~b, ga, 'g'^~b, ga^~b ),
  DH( ~b, ~session_id, $S ), Start( $S, $C, 'server', ~session_id ),
  Reach( 'SH' )
  ]->
   [
   Out( <$S, $C, '22', %1, %1, ~msg_len, '2', <~msg_len, %1, %1, %1>, 
         protocolVersion, ~session_id, 'CipherSuits', '41', 
         <psk_id_1, ~obfuscated_ticket_age>, '51', 'g', 'g'^~b>
   ),
   !Keys( <$S, $C, ~session_id, 'g'^~b, ga, ga^~b, psk_1> ),
   St_ServerHello( <$S, $C, 
                    <'1', protocolVersion, client_session_id, 'CipherSuits', '41', 
                     psk_id_1, '45', '1', '51', 'g', ga>, 
                    '2', protocolVersion, ~session_id, 'CipherSuits', '41', 
                    <psk_id_1, ~obfuscated_ticket_age>, '51', 'g', 'g'^~b>,
                   <psk_id_1, psk_1>, <client_session_id, ~session_id>,
                   <~session_id, %1, (%1%+%1), %1, (%1%+%1)>
   ),
   DHExp( ~b, ~session_id, $S )
   ]

  /*
  rule (modulo AC) ServerHello:
     [
     Fr( ~obfuscated_ticket_age ), Fr( ~session_id ), Fr( ~b ),
     Fr( ~msg_len ), S_In( <$C, $S, psk_id_1, psk_1> ),
     In( <$C, $S, '22', %1, %1, lenCH, '1', <lenCH, %1, %1, %1>, 
          <'254', '253'>, client_session_id, 'CipherSuits', '41', psk_id_1, 
          '45', '1', '51', 'g', ga>
     )
     ]
    --[
    Neq( 'g', ga ), Neq( ga, z ),
    DHChal( $S, ~session_id, 'g', ~b, ga, 'g'^~b, z ),
    DH( ~b, ~session_id, $S ), Start( $S, $C, 'server', ~session_id ),
    Reach( 'SH' )
    ]->
     [
     Out( <$S, $C, '22', %1, %1, ~msg_len, '2', <~msg_len, %1, %1, %1>, 
           <'254', '253'>, ~session_id, 'CipherSuits', '41', 
           <psk_id_1, ~obfuscated_ticket_age>, '51', 'g', 'g'^~b>
     ),
     !Keys( <$S, $C, ~session_id, 'g'^~b, ga, z, psk_1> ),
     St_ServerHello( <$S, $C, 
                      <'1', <'254', '253'>, client_session_id, 'CipherSuits', '41', 
                       psk_id_1, '45', '1', '51', 'g', ga>, 
                      '2', <'254', '253'>, ~session_id, 'CipherSuits', '41', 
                      <psk_id_1, ~obfuscated_ticket_age>, '51', 'g', 'g'^~b>,
                     <psk_id_1, psk_1>, <client_session_id, ~session_id>,
                     <~session_id, %1, (%1%+%1), %1, (%1%+%1)>
     ),
     DHExp( ~b, ~session_id, $S )
     ]
    variants (modulo AC)
    1. ~b    = ~b.30
       ga    = ga.35
       z     = ga.35^~b.30
    
    2. ~b    = ~b.45
       ga    = z.65^inv(~b.45)
       z     = z.65
    
    3. ~b    = ~b.383
       ga    = x.761^x.762
       z     = x.761^(~b.383*x.762)
    
    4. ~b    = ~b.388
       ga    = x.771^inv((~b.388*x.772))
       z     = x.771^inv(x.772)
    
    5. ~b    = ~b.388
       ga    = x.771^(x.772*inv(~b.388))
       z     = x.771^x.772
    
    6. ~b    = ~b.389
       ga    = x.772^(x.773*inv((~b.389*x.774)))
       z     = x.772^(x.773*inv(x.774))
    
    7. ga    = DH_neutral
       z     = DH_neutral
  */

rule (modulo E) EncryptedExtensions:
   [
   Fr( ~msg_len ),
   St_ServerHello( <$S, $C, ClientHello, ServerHello>,
                   <psk_id_1, psk_1>, nonce,
                   <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
   ),
   !Keys( <$S, $C, session_id, gb, ga, traffic_key> )
   ]
  --[
  Instance( session_id, $S, 'server' ),
  Send( $S, $C, 'EE', session_id ), Reach( 'EE' )
  ]->
   [
   Out( <$S, $C, handshakeCryptoHeader, 
         senc(<
               <'8', <~msg_len, %next_seq, %1, %1>, '13', 'encryptedExtensions'>, 
               '0', '22'>,
              traffic_key)
        >
   ),
   St_EncryptedExtensions( <$S, $C, ClientHello, ServerHello, '8', 
                            '13', 'encryptedExtensions'>,
                           <psk_id_1, psk_1>, nonce,
                           <session_id, (%next_seq%+%1), %next_epoch, %rec_seq, %rec_epoch>
   )
   ]

  /*
  rule (modulo AC) EncryptedExtensions:
     [
     Fr( ~msg_len ),
     St_ServerHello( <$S, $C, ClientHello, ServerHello>,
                     <psk_id_1, psk_1>, nonce,
                     <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
     ),
     !Keys( <$S, $C, session_id, gb, ga, traffic_key> )
     ]
    --[
    Instance( session_id, $S, 'server' ),
    Send( $S, $C, 'EE', session_id ), Reach( 'EE' )
    ]->
     [
     Out( <$S, $C, <<'0', '0', '1'>, '0', '1', '1', '1', '0'>, 
           senc(<
                 <'8', <~msg_len, %next_seq, %1, %1>, '13', 'encryptedExtensions'>, 
                 '0', '22'>,
                traffic_key)
          >
     ),
     St_EncryptedExtensions( <$S, $C, ClientHello, ServerHello, '8', 
                              '13', 'encryptedExtensions'>,
                             <psk_id_1, psk_1>, nonce,
                             <session_id, (%next_seq%+%1), %next_epoch, %rec_seq, %rec_epoch>
     )
     ]
  */

rule (modulo E) ServerFinished:
   [
   Fr( ~msg_len ),
   St_EncryptedExtensions( <$S, $C, ClientHello, ServerHello, 
                            EncryptedExtensions>,
                           <psk_id_1, psk_1>, nonce,
                           <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
   ),
   !Keys( <$S, $C, session_id, gb, ga, traffic_key> )
   ]
  --[
  Instance( session_id, $S, 'server' ),
  Send( $S, $C, 'SF', session_id ), Reach( 'SF' ),
  RunningAuth( $S, 'server', session_id,
               <ClientHello, ServerHello, EncryptedExtensions, '20', 
                hmac(<HKDFExpand(<traffic_key, 'finished', 'Hash_length'>), 
                      h1(<ClientHello, ServerHello, EncryptedExtensions>)>)
               >,
               <psk_id_1, psk_1>
  ),
  Running( $S, 'server', session_id,
           <ClientHello, ServerHello, EncryptedExtensions>, traffic_key
  )
  ]->
   [
   Out( <$S, $C, handshakeCryptoHeader, 
         senc(<
               <'20', <~msg_len, %next_seq, %1, %1>, 
                hmac(<HKDFExpand(<traffic_key, 'finished', 'Hash_length'>), 
                      h1(<ClientHello, ServerHello, EncryptedExtensions>)>)
               >, 
               '0', '22'>,
              traffic_key)
        >
   ),
   St_ServerFinished( $S, $C, session_id,
                      <ClientHello, ServerHello, EncryptedExtensions, '20', 
                       hmac(<HKDFExpand(<traffic_key, 'finished', 'Hash_length'>), 
                             h1(<ClientHello, ServerHello, EncryptedExtensions>)>)
                      >,
                      <psk_id_1, psk_1>
   ),
   ServerFinished( <$S, $C, 
                    <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>, 
                    hmac(<HKDFExpand(<traffic_key, 'finished', 'Hash_length'>), 
                          h1(<ClientHello, ServerHello, EncryptedExtensions>)>), 
                    session_id, nonce, 
                    HKDFExpand(<traffic_key, 'finished', 'Hash_length'>)>
   ),
   FinalKey( $S, $C,
             HKDFExpand(<traffic_key, 'finished', 'Hash_length'>)
   )
   ]

  /*
  rule (modulo AC) ServerFinished:
     [
     Fr( ~msg_len ),
     St_EncryptedExtensions( <$S, $C, ClientHello, ServerHello, 
                              EncryptedExtensions>,
                             <psk_id_1, psk_1>, nonce,
                             <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
     ),
     !Keys( <$S, $C, session_id, gb, ga, traffic_key> )
     ]
    --[
    Instance( session_id, $S, 'server' ),
    Send( $S, $C, 'SF', session_id ), Reach( 'SF' ),
    RunningAuth( $S, 'server', session_id,
                 <ClientHello, ServerHello, EncryptedExtensions, '20', 
                  hmac(<HKDFExpand(<traffic_key, 'finished', 'Hash_length'>), 
                        h1(<ClientHello, ServerHello, EncryptedExtensions>)>)
                 >,
                 <psk_id_1, psk_1>
    ),
    Running( $S, 'server', session_id,
             <ClientHello, ServerHello, EncryptedExtensions>, traffic_key
    )
    ]->
     [
     Out( <$S, $C, <<'0', '0', '1'>, '0', '1', '1', '1', '0'>, 
           senc(<
                 <'20', <~msg_len, %next_seq, %1, %1>, 
                  hmac(<HKDFExpand(<traffic_key, 'finished', 'Hash_length'>), 
                        h1(<ClientHello, ServerHello, EncryptedExtensions>)>)
                 >, 
                 '0', '22'>,
                traffic_key)
          >
     ),
     St_ServerFinished( $S, $C, session_id,
                        <ClientHello, ServerHello, EncryptedExtensions, '20', 
                         hmac(<HKDFExpand(<traffic_key, 'finished', 'Hash_length'>), 
                               h1(<ClientHello, ServerHello, EncryptedExtensions>)>)
                        >,
                        <psk_id_1, psk_1>
     ),
     ServerFinished( <$S, $C, 
                      <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>, 
                      hmac(<HKDFExpand(<traffic_key, 'finished', 'Hash_length'>), 
                            h1(<ClientHello, ServerHello, EncryptedExtensions>)>), 
                      session_id, nonce, 
                      HKDFExpand(<traffic_key, 'finished', 'Hash_length'>)>
     ),
     FinalKey( $S, $C,
               HKDFExpand(<traffic_key, 'finished', 'Hash_length'>)
     )
     ]
  */

rule (modulo E) ClientFinished:
   [
   Fr( ~msg_len ),
   St_ClientHello( <$C, $S, <a, psk_1>, session_id>, ClientHello,
                   <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
   ),
   In( <$S, $C, '22', %rec_epoch, %rec_seq, lenSH, '2', 
        <lenSH, %rec_seq, %1, %1>, protocolVersion, server_session_id, 
        'CipherSuits', '41', <psk_id_1, obfuscated_ticket_age>, '51', 'g', 
        gb>
   ),
   In( <$S, $C, handshakeCryptoHeader, 
        senc(<<'8', <lenEE, %1, %1, %1>, '13', 'encryptedExtensions'>, 
              '0', '22'>,
             <gb^a, psk_1>)
       >
   ),
   In( <$S, $C, handshakeCryptoHeader, 
        senc(<<'20', <lenSF, (%1%+%1), %1, %1>, server_finished>, '0', '22'
             >,
             <gb^a, psk_1>)
       >
   )
   ]
  --[
  HandshakeComplete( $C, $S, 'client', <gb^a, psk_1>,
                     <session_id, server_session_id>
  ),
  DHChal( $C, session_id, 'g', a, 'g'^a, gb, gb^a ),
  Eq( hmac(<HKDFExpand(<<gb^a, psk_1>, 'finished', 'Hash_length'>), 
            h1(<ClientHello, 
                <'2', protocolVersion, server_session_id, 'CipherSuits', '41', 
                 <psk_id_1, obfuscated_ticket_age>, '51', 'g', gb>, 
                '8', '13', 'encryptedExtensions'>)
           >),
      server_finished
  ),
  Neq( 'g', gb ), Neq( gb, gb^a ),
  RunningAuth( $C, 'client', session_id,
               <ClientHello, 
                <'2', protocolVersion, server_session_id, 'CipherSuits', '41', 
                 <psk_id_1, obfuscated_ticket_age>, '51', 'g', gb>, 
                <'8', '13', 'encryptedExtensions'>, '20', server_finished>,
               <psk_id_1, psk_1>
  ),
  CommitAuth( $C, $S, 'client', session_id,
              <ClientHello, 
               <'2', protocolVersion, server_session_id, 'CipherSuits', '41', 
                <psk_id_1, obfuscated_ticket_age>, '51', 'g', gb>, 
               <'8', '13', 'encryptedExtensions'>, '20', server_finished>,
              <psk_id_1, psk_1>
  ),
  Running( $C, 'client', session_id,
           <ClientHello, 
            <'2', protocolVersion, server_session_id, 'CipherSuits', '41', 
             <psk_id_1, obfuscated_ticket_age>, '51', 'g', gb>, 
            <'8', '13', 'encryptedExtensions'>, '20', server_finished>,
           <gb^a, psk_1>
  ),
  Instance( session_id, $C, 'client' ),
  SessionKey( $C, $S, 'client', session_id, <gb^a, psk_1>, 'auth' )
  ]->
   [
   Out( <$C, $S, handshakeCryptoHeader, 
         senc(<
               <'20', <~msg_len, %next_seq, %1, %1>, 
                hmac(<HKDFExpand(<<gb^a, psk_1>, 'finished', 'Hash_length'>), 
                      h1(<ClientHello, 
                          <'2', protocolVersion, server_session_id, 'CipherSuits', '41', 
                           <psk_id_1, obfuscated_ticket_age>, '51', 'g', gb>, 
                          '8', '13', 'encryptedExtensions'>)
                     >)
               >, 
               <'0', '0'>, '22'>,
              <gb^a, psk_1>)
        >
   ),
   !ClientSessionKey( $C, $S, session_id,
                      HKDFExpand(<<gb^a, psk_1>, 'finished', 'Hash_length'>)
   )
   ]

  /*
  rule (modulo AC) ClientFinished:
     [
     Fr( ~msg_len ),
     St_ClientHello( <$C, $S, <a, psk_1>, session_id>, ClientHello,
                     <session_id, %next_seq, %next_epoch, %rec_seq, %rec_epoch>
     ),
     In( <$S, $C, '22', %rec_epoch, %rec_seq, lenSH, '2', 
          <lenSH, %rec_seq, %1, %1>, <'254', '253'>, server_session_id, 
          'CipherSuits', '41', <psk_id_1, obfuscated_ticket_age>, '51', 'g', 
          gb>
     ),
     In( <$S, $C, <<'0', '0', '1'>, '0', '1', '1', '1', '0'>, 
          senc(<<'8', <lenEE, %1, %1, %1>, '13', 'encryptedExtensions'>, 
                '0', '22'>,
               <z, psk_1>)
         >
     ),
     In( <$S, $C, <<'0', '0', '1'>, '0', '1', '1', '1', '0'>, 
          senc(<<'20', <lenSF, (%1%+%1), %1, %1>, server_finished>, '0', '22'
               >,
               <z, psk_1>)
         >
     )
     ]
    --[
    HandshakeComplete( $C, $S, 'client', <z, psk_1>,
                       <session_id, server_session_id>
    ),
    DHChal( $C, session_id, 'g', a, z.1, gb, z ),
    Eq( hmac(<HKDFExpand(<<z, psk_1>, 'finished', 'Hash_length'>), 
              h1(<ClientHello, 
                  <'2', <'254', '253'>, server_session_id, 'CipherSuits', '41', 
                   <psk_id_1, obfuscated_ticket_age>, '51', 'g', gb>, 
                  '8', '13', 'encryptedExtensions'>)
             >),
        server_finished
    ),
    Neq( 'g', gb ), Neq( gb, z ),
    RunningAuth( $C, 'client', session_id,
                 <ClientHello, 
                  <'2', <'254', '253'>, server_session_id, 'CipherSuits', '41', 
                   <psk_id_1, obfuscated_ticket_age>, '51', 'g', gb>, 
                  <'8', '13', 'encryptedExtensions'>, '20', server_finished>,
                 <psk_id_1, psk_1>
    ),
    CommitAuth( $C, $S, 'client', session_id,
                <ClientHello, 
                 <'2', <'254', '253'>, server_session_id, 'CipherSuits', '41', 
                  <psk_id_1, obfuscated_ticket_age>, '51', 'g', gb>, 
                 <'8', '13', 'encryptedExtensions'>, '20', server_finished>,
                <psk_id_1, psk_1>
    ),
    Running( $C, 'client', session_id,
             <ClientHello, 
              <'2', <'254', '253'>, server_session_id, 'CipherSuits', '41', 
               <psk_id_1, obfuscated_ticket_age>, '51', 'g', gb>, 
              <'8', '13', 'encryptedExtensions'>, '20', server_finished>,
             <z, psk_1>
    ),
    Instance( session_id, $C, 'client' ),
    SessionKey( $C, $S, 'client', session_id, <z, psk_1>, 'auth' )
    ]->
     [
     Out( <$C, $S, <<'0', '0', '1'>, '0', '1', '1', '1', '0'>, 
           senc(<
                 <'20', <~msg_len, %next_seq, %1, %1>, 
                  hmac(<HKDFExpand(<<z, psk_1>, 'finished', 'Hash_length'>), 
                        h1(<ClientHello, 
                            <'2', <'254', '253'>, server_session_id, 'CipherSuits', '41', 
                             <psk_id_1, obfuscated_ticket_age>, '51', 'g', gb>, 
                            '8', '13', 'encryptedExtensions'>)
                       >)
                 >, 
                 <'0', '0'>, '22'>,
                <z, psk_1>)
          >
     ),
     !ClientSessionKey( $C, $S, session_id,
                        HKDFExpand(<<z, psk_1>, 'finished', 'Hash_length'>)
     )
     ]
    variants (modulo AC)
     1. a     = a.40
        gb    = DH_neutral
        z     = DH_neutral
        z.1   = 'g'^a.40
    
     2. a     = a.41
        gb    = gb.42
        z     = gb.42^a.41
        z.1   = 'g'^a.41
    
     3. a     = a.68
        gb    = z.96^inv(a.68)
        z     = z.96
        z.1   = 'g'^a.68
    
     4. a     = a.636
        gb    = x.1265^x.1266
        z     = x.1265^(a.636*x.1266)
        z.1   = 'g'^a.636
    
     5. a     = a.637
        gb    = x.1267^inv((a.637*x.1268))
        z     = x.1267^inv(x.1268)
        z.1   = 'g'^a.637
    
     6. a     = a.637
        gb    = x.1267^(x.1268*inv(a.637))
        z     = x.1267^x.1268
        z.1   = 'g'^a.637
    
     7. a     = a.638
        gb    = x.1268^(x.1269*inv((a.638*x.1270)))
        z     = x.1268^(x.1269*inv(x.1270))
        z.1   = 'g'^a.638
    
     8. a     = inv(x.42)
        gb    = x.43^inv(x.44)
        z     = x.43^inv((x.42*x.44))
        z.1   = 'g'^inv(x.42)
    
     9. a     = inv(x.42)
        gb    = x.43^(x.42*x.44)
        z     = x.43^x.44
        z.1   = 'g'^inv(x.42)
    
    10. a     = inv(x.43)
        gb    = x.44^(x.45*inv(x.46))
        z     = x.44^(x.45*inv((x.43*x.46)))
